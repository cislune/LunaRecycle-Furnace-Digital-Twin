    set('auto_tc_platenCp', platenCp, 3);
    set('auto_tc_polymerCp', chargeCp, 3);
    set('auto_tc_dieCapacity', dieCapacity, 3);
    set('auto_tc_platenCapacity', platenCapacity, 3);
    set('auto_tc_chargeCapacity', chargeCapacity, 3);
    set('auto_tc_totalCapacity', total, 3);
    set('auto_tc_platenParticipation', participation, 3);
    set('tc_effectiveThermalCapacity', total, 3);
    set('auto_tc_singlePass', byId('lrc_tc_singlePass')?.checked === false ? 'Disabled' : 'Enabled');
    set('auto_tc_pressureLogic', 'Automatic limit and consistency checks');
    set('auto_tc_heatModel', 'Lumped-capacitance estimate; calibration recommended');
    set('auto_tc_recoveryBasis', chargeMaterial + '; temperature-adjusted mean cp');
    set('auto_tc_envelope', 'Within configured limits');
  }

  function syncAll(){
    syncMagnetic();
    syncPyrolysis();
    syncThermocompression();
  }

  const watched = [
    'mb_magnetGrade','mb_separatorGeometry','mb_psdModeVisible','mb_psdMode','simulantPreset','mb_d50um',
    'materialPreset','customMoistPct','customInertFrac','A1','Ea1','vf_lowVolFrac','vf_lowLiqCapture',
    'vp_severity','vp_solidRecovery','dt','ctrlUpdate','Cfurn','Cload','tauCham','tauSamp','maxCool','T0','mfPower','mfEff','mfLoss','mfPyroTemp','mfPyroHold','mfCtrTemp','mfCtrHold','mfPyroDH','mfCtrDH',
    'tc_dieMaterialCalc','tc_platenMaterialCalc','tc_material','tc_dieMassKg','tc_platenMassKg',
    'lrc_tc_charge','tc_setpoint','lrc_tc_singlePass'
  ];
  watched.forEach(id => {
    const el = byId(id);
    if (!el) return;
    el.addEventListener('input', syncAll);
    el.addEventListener('change', syncAll);
  });
  ['mb_runBtn','runBtn','lrc_tc_btn'].forEach(id => {
    byId(id)?.addEventListener('click', () => setTimeout(syncAll, 0));
  });
  syncAll();
})();
