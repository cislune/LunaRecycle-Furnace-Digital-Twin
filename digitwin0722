function calcSteelFromFactSage(){
  const q = getFactSageQuery();
  const savedRuns = loadRuns();
  const closest = closestRun(savedRuns, q);
  if (!closest){
    fs_steelOut.textContent = "ERROR: Save at least one FactSage run for the current simulant first.";
    return;
  }

  const runBasis = Number(closest.regolithBasis || 0);
  if (!(runBasis > 0) || !(q.regolithBasis > 0)){
    fs_steelOut.textContent = "ERROR: Current and saved FactSage regolith bases must both be greater than zero.";
    return;
  }

  const scale = q.regolithBasis / runBasis;
  const importedMetal = Math.max(0, Number(closest.mMetal_g || 0)) * scale;
  const importedSlag = Math.max(0, Number(closest.mSlag_g || 0)) * scale;
  const importedCOmol = Math.max(0, Number(closest.nCO_mol || 0)) * scale;
  const importedCO2mol = Math.max(0, Number(closest.nCO2_mol || 0)) * scale;
  const importedCleft = Math.max(0, Number(closest.mCleft_g || 0)) * scale;

  const ctrOpts = getInputsForRun();
  const ctrTemp = Number(mfCtrTempInput ? mfCtrTempInput.value : 1600);
  const ctrHoldMin = Math.max(0, Number(mfCtrHoldInput ? mfCtrHoldInput.value : 120));
  const ctrDH = Math.max(0, Number(mfCtrDHInput ? mfCtrDHInput.value : 1800));
  const ctrHeat = mantleHeatDuty(ctrTemp, ctrOpts, q.regolithBasis, ctrDH);

  // Chemistry-only balance for FeO and Fe2O3. This is used only when the
  // closest saved FactSage run does not contain a positive metal-phase mass.
  // It is an upper-bound reduction balance, not a substitute for equilibrium
  // or kinetic phase prediction.
  const ox = q.ox || {};
  const MW_FE = 55.845;
  const MW_O = 15.999;
  const MW_C = 12.011;
  const MW_FEO = MW_FE + MW_O;
  const MW_FE2O3 = 2 * MW_FE + 3 * MW_O;

  const mFeO = q.regolithBasis * Math.max(0, Number(ox.FeO || 0)) / 100.0;
  const mFe2O3 = q.regolithBasis * Math.max(0, Number(ox.Fe2O3 || 0)) / 100.0;

  const fePotentialFromFeO = mFeO * MW_FE / MW_FEO;
  const fePotentialFromFe2O3 = mFe2O3 * (2 * MW_FE) / MW_FE2O3;
  const theoreticalFe = fePotentialFromFeO + fePotentialFromFe2O3;

  // Stoichiometry assumes CO as the oxygen-bearing reduction product:
  // FeO + C -> Fe + CO
  // Fe2O3 + 3C -> 2Fe + 3CO
  const cRequiredFeO = (mFeO / MW_FEO) * MW_C;
  const cRequiredFe2O3 = (mFe2O3 / MW_FE2O3) * 3 * MW_C;
  const carbonRequired = cRequiredFeO + cRequiredFe2O3;

  const charMass = Math.max(0, Number(getEffectiveCharMass() || 0));
  const fixedCarbonFrac = Math.max(0, Math.min(1, Number(p3_marginPct ? p3_marginPct.value : 80) / 100.0));
  const carbonAvailable = charMass * fixedCarbonFrac;
  const carbonReductionFraction = carbonRequired > 0
    ? Math.max(0, Math.min(1, carbonAvailable / carbonRequired))
    : 0;

  // Do not invent a kinetic conversion curve. The chemistry-only result is
  // enabled only when the run is actually inside the modeled CTR range and a
  // positive hold time is provided. FactSage remains the authoritative source
  // for temperature-dependent equilibrium yield.
  const ctrConditionMet = Number.isFinite(ctrTemp) && ctrTemp >= 1200 && ctrTemp <= 1800 && ctrHoldMin > 0;
  const chemistryReductionFraction = ctrConditionMet ? carbonReductionFraction : 0;
  const chemistryMetal = theoreticalFe * chemistryReductionFraction;

  const oxygenInFeO = mFeO * MW_O / MW_FEO;
  const oxygenInFe2O3 = mFe2O3 * (3 * MW_O) / MW_FE2O3;
  const oxygenRemoved = (oxygenInFeO + oxygenInFe2O3) * chemistryReductionFraction;
  const carbonConsumed = carbonRequired * chemistryReductionFraction;
  const chemistryCOmass = oxygenRemoved + carbonConsumed;
  const chemistryCOmol = chemistryCOmass / (MW_C + MW_O);
  const chemistryResidualSolids = Math.max(0, q.regolithBasis - oxygenRemoved);
  const chemistrySlag = Math.max(0, chemistryResidualSolids - chemistryMetal);

  const useImported = importedMetal > 0;
  const metalProduct = useImported ? importedMetal : chemistryMetal;
  const slagProduct = useImported
    ? importedSlag
    : chemistrySlag;
  const metalYieldPct = q.regolithBasis > 0 ? 100 * metalProduct / q.regolithBasis : 0;
  const theoreticalFePct = q.regolithBasis > 0 ? 100 * theoreticalFe / q.regolithBasis : 0;

  const exactOxides = String(closest.oxHash || "") === String(q.oxHash || "");
  const exactTemp = Math.abs(Number(closest.Tc) - q.Tc) < 1e-9;
  const exactPressure = Math.abs(Number(closest.Pbar) - q.Pbar) < 1e-9;
  const exactCarbon = Math.abs(Number(closest.cMult) - q.cMult) < 1e-9;
  const exactConditions = exactOxides && exactTemp && exactPressure && exactCarbon;

  const resultBasis = useImported
    ? "Scaled metal phase from the closest saved FactSage equilibrium run"
    : "Stoichiometric, carbon-limited Fe upper bound because the saved FactSage metal phase is zero";

  fs_steelOut.textContent =
`================ CTR / METAL PRODUCTION RESULT ====================
Key inputs for reference
  Simulant: ${closest.simulantName || q.simulantName}
  Process stream: ${getProcessBasisLabel()}
  Current dry-regolith basis [g]: ${q.regolithBasis.toFixed(3)}
  CTR setpoint [C]: ${ctrTemp.toFixed(2)}
  CTR hold time [min]: ${ctrHoldMin.toFixed(2)}
  Available fixed carbon [g]: ${carbonAvailable.toFixed(6)}
  Mantle-furnace power [W]: ${ctrOpts.furnacePowerW.toFixed(2)}
  Thermal efficiency [-]: ${ctrOpts.thermalEff.toFixed(3)}

Closest saved-run basis [g]: ${runBasis.toFixed(3)}
Scale factor [-]: ${scale.toFixed(6)}
Saved-run condition match: ${exactConditions ? "exact composition / T / P / carbon multiplier" : "closest available run; review mismatch before treating as calibrated"}

Metal product [g]: ${metalProduct.toFixed(6)}
Metal yield from current dry-regolith basis [wt%]: ${metalYieldPct.toFixed(4)}
Metal carbon [wt% C]: ${useImported ? Number(closest.wCmetal_wt || 0).toFixed(3) : "not predicted without FactSage"}
Slag / residual mineral [g]: ${slagProduct.toFixed(6)}

${useImported
? `Imported FactSage products scaled to current basis
  Metal phase [g]: ${importedMetal.toFixed(6)}
  Slag phase [g]: ${importedSlag.toFixed(6)}
  CO [mol]: ${importedCOmol.toFixed(6)}
  CO2 [mol]: ${importedCO2mol.toFixed(6)}
  Unreacted carbon [g]: ${importedCleft.toFixed(6)}`
: `Chemistry-only Fe reduction balance
  FeO in current stream [g]: ${mFeO.toFixed(6)}
  Fe2O3 in current stream [g]: ${mFe2O3.toFixed(6)}
  Theoretical elemental Fe inventory [g]: ${theoreticalFe.toFixed(6)}
  Theoretical Fe inventory [wt% of dry regolith]: ${theoreticalFePct.toFixed(4)}
  Stoichiometric carbon required [g]: ${carbonRequired.toFixed(6)}
  Carbon-limited reduction fraction [-]: ${carbonReductionFraction.toFixed(6)}
  CTR temperature/hold condition met: ${ctrConditionMet ? "yes" : "no"}
  Oxygen removed from Fe oxides [g]: ${oxygenRemoved.toFixed(6)}
  Carbon consumed [g]: ${carbonConsumed.toFixed(6)}
  Estimated CO generated [mol]: ${chemistryCOmol.toFixed(6)}
  Note: this branch is an upper-bound Fe balance; import a positive FactSage metal phase for equilibrium metal/slag prediction.`}

Mantle-furnace CTR heat requirement
  Initial temperature [C]: ${Number(ctrOpts.T0 ?? 25).toFixed(2)}
  CTR setpoint [C]: ${ctrTemp.toFixed(2)}
  Estimated heat-up time [min]: ${(ctrHeat.heatupSec/60).toFixed(2)}
  CTR hold time [min]: ${ctrHoldMin.toFixed(2)}
  Sensible heat [kJ]: ${ctrHeat.sensibleKJ.toFixed(3)}
  Effective CTR reaction heat [kJ]: ${ctrHeat.reactionKJ.toFixed(3)}
  Estimated electrical heat [kJ]: ${ctrHeat.electricalKJ.toFixed(3)}
  Estimated electrical energy [kWh]: ${ctrHeat.electricalKWh.toFixed(6)}
==================================================================`;
}

