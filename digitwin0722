    function getBaselineForAirIngress(){
      const src = p5_baseSource.value;

      // Prefer requested source if available; otherwise fall back gracefully.
      if (src === "part4" && outageState.ran){
        return {
          label: "Part 4 outage",
          mChar: outageState.mChar,
          t500: outageState.t500,
          t700: outageState.t700,
          Tpeak: outageState.Tpeak
        };
      }
      if (pyroState.ran){
        // We don't store nominal t500/t700 in pyroState, but we can re-run a quick nominal sim to recover thermal metrics.
        // To keep existing behavior unchanged, we reuse the same model inputs and simulate once to get t500/t700.
        const opts = getInputsForRun();
        const res = simulatePyrolysisWithThermal(opts, null);
        return {
          label: "Part 1 nominal",
          mChar: pyroState.mChar,
          t500: res.t500,
          t700: res.t700,
          Tpeak: res.Tpeak
        };
      }
      return null;
    }

    function hotTimeFromThreshold(Tstar, baseline){
      // We only have t500 and t700 as robust exposure metrics.
      // If user chooses Tâ between 500 and 700, linearly interpolate between the two times.
      // If below 500: treat as t500 (conservative; oxidation would be greater in reality).
      // If above 700: treat as t700 (conservative; oxidation would be smaller in reality).
      const t500 = Number(baseline.t500);
      const t700 = Number(baseline.t700);

      if (!Number.isFinite(t500) || !Number.isFinite(t700)) return NaN;

      if (Tstar <= 500) return t500;
      if (Tstar >= 700) return t700;

      const f = (Tstar - 500) / 200.0; // 500->700
      return (1 - f)*t500 + f*t700;
    }

    function runAirIngress(){
      p5_out.textContent = "Running air ingress modelâ¦";
      try{
        const baseline = getBaselineForAirIngress();
        if (!baseline){
          p5_out.textContent = "ERROR: Run Part 1 (or Part 4) first so baseline char + thermal exposure exist.";
          airLeakState.ran = false;
          airLeakState.use = false;
          p5_statusPill.textContent = "Not run";
          refreshCharToPart2();
          refreshPart3GatePreview();
          return;
        }

        const Tstar = Number(p5_Tstar.value);
        const kox = Number(p5_kox.value);
        const o2Pct = Number(p5_o2Pct ? p5_o2Pct.value : 21);
        const measuredIngressSec = Number(p5_leakDurationMult ? p5_leakDurationMult.value : 0);

        if (!Number.isFinite(Tstar)) throw new Error("Tâ must be a number.");
        if (!(kox >= 0)) throw new Error("kââ must be â¥ 0.");
        if (!(o2Pct >= 0 && o2Pct <= 21)) throw new Error("Oâ ingress concentration must be between 0 and 21 vol%.");
        if (!(measuredIngressSec >= 0)) throw new Error("Measured ingress duration must be â¥ 0.");

        const tHotBase = hotTimeFromThreshold(Tstar, baseline);
        const exposureBase = measuredIngressSec > 0 ? measuredIngressSec : tHotBase;
        const tHot = exposureBase * (o2Pct / 21.0);
        if (!Number.isFinite(tHot)){
          throw new Error("Could not compute time-at-temperature. Check that Part 1/4 produced thermal metrics.");
        }

        const mBase = Number(baseline.mChar);
        if (!(mBase >= 0)) throw new Error("Baseline char mass invalid.");

        const mOx = mBase * Math.exp(-kox * tHot);
        const dChar = mOx - mBase;

        airLeakState.ran = true;
        airLeakState.use = true;
        airLeakState.baseSource = p5_baseSource.value;
        airLeakState.Tstar = Tstar;
        airLeakState.kox = kox;
        airLeakState.mCharOx = mOx;
        airLeakState.dChar = dChar;
        airLeakState.tHot = tHot;

        p5_statusPill.textContent = "Ran";

        p5_out.textContent =
`Baseline source:                   ${baseline.label}
Baseline char [g]:                 ${mBase.toFixed(6)}
Oxidation exposure [s]:            ${Math.round(tHot)}
Oxidized char [g]:                 ${mOx.toFixed(6)}
Char lost [g]:                     ${Math.max(0, -dChar).toFixed(6)}`;

        // Update downstream displays (Part 2 char + Part 3 carbon gate) if forwarding enabled
        refreshCharToPart2();
        refreshPart3GatePreview();

      } catch(e){
        p5_out.textContent = `ERROR: ${e.message}`;
        console.error(e);
        airLeakState.ran = false;
        airLeakState.use = false;
        p5_statusPill.textContent = "Not run";
        refreshCharToPart2();
        refreshPart3GatePreview();
      }
    }

