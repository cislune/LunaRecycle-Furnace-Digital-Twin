function currentFeedstockLabel(){
  const key = materialPreset ? materialPreset.value : "custom";
  if (key === "blend") return "Mixed waste feedstock blend";
  const p = PRESETS[key] || PRESETS.custom;
  return p.name || "Custom feedstock";
}


function getCurrentWasteWetMassDefault(){
  const key = materialPreset ? materialPreset.value : "custom";
  if (key === "blend") {
    try { return computeBlendFeedstock().totalWet; } catch(e) { return 0; }
  }
  return Number(wetMass ? wetMass.value : 0);
}

function getWasteBalanceFromWet(enteredWetMass){
  const key = materialPreset ? materialPreset.value : "custom";
  const enteredWet = Math.max(0, Number(enteredWetMass || 0));

  if (key === "blend"){
    const blend = computeBlendFeedstock();
    const scale = blend.totalWet > 0 ? enteredWet / blend.totalWet : 0;
    return {
      key,
      label: "Mixed waste feedstock blend",
      mWet: enteredWet,
      mReactive: blend.totalReactive * scale,
      mDry: blend.totalDry * scale,
      mInertRemoved: Math.max(0, (blend.totalWet - blend.totalReactive) * scale),
      mWaterRemoved: Math.max(0, (blend.totalReactive - blend.totalDry) * scale),
      note: "Blend moisture and inert removal are scaled from the entered as-received blend mass."
    };
  }

  const mWetEntered = enteredWet;
  let inert = 0;
  let moist = 0;
  let label = "Custom feedstock";

  if (key === "custom"){
    inert = clamp(Number(customInertFrac ? customInertFrac.value : 0), 0, 0.99);
    moist = clamp(Number(customMoistPct ? customMoistPct.value : 0) / 100.0, 0, 0.99);
    label = "Custom feedstock";
  } else {
    const p = PRESETS[key] || PRESETS.custom;
    inert = clamp(Number(p.inertFrac || 0), 0, 0.99);
    moist = clamp(Number(p.moistPct || 0) / 100.0, 0, 0.99);
    label = p.name || "Preset feedstock";
  }

  const mReactive = (1 - inert) * mWetEntered;
  const mDry = (1 - moist) * mReactive;
  return {
    key,
    label,
    mWet: mWetEntered,
    mReactive,
    mDry,
    mInertRemoved: Math.max(0, mWetEntered - mReactive),
    mWaterRemoved: Math.max(0, mReactive - mDry),
    note: "Moisture is removed as sublimed water before product yields are applied."
  };
}

function getRegolithVacuumBalance(enteredLoadedMass){
  const mLoaded = Math.max(0, Number(enteredLoadedMass || 0));
  const loi = clamp(Number(p2_loiPct ? p2_loiPct.value : 0), 0, 50) / 100.0;
  const mDry = mLoaded * (1 - loi);
  return {
    mLoaded,
    loiPct: loi * 100,
    mWaterRemoved: Math.max(0, mLoaded - mDry),
    mDry
  };
}

function getVacuumRegolithImport(){
  const source = pyro_regolithSource ? pyro_regolithSource.value : "unbeneficiated";
  const part1Basis = Number(p2_regolithBasis ? p2_regolithBasis.value : 1000);
  const fallbackFeed = Number.isFinite(part1Basis) ? part1Basis : 1000;

  if (source === "magnetic") {
    const mass = benefState.ran && Number.isFinite(Number(benefState.mConc)) ? Number(benefState.mConc) : fallbackFeed;
    return {
      source,
      mass,
      label: "magnetically beneficiated concentrate",
      note: benefState.ran
        ? `Imported magnetic-bin concentrate from Part 2 (${mass.toFixed(3)} g). Editable before run.`
        : "Run Part 2 to import magnetic-bin concentrate. Using current regolith basis for now; editable."
    };
  }

  if (source === "nonmagnetic") {
    const mass = benefState.ran && Number.isFinite(Number(benefState.mNonMagBin)) ? Number(benefState.mNonMagBin) : fallbackFeed;
    return {
      source,
      mass,
      label: "non-magnetic separated portion",
      note: benefState.ran
        ? `Imported non-magnetic-bin mass from Part 2 (${mass.toFixed(3)} g). Editable before run.`
        : "Run Part 2 to import non-magnetic separated mass. Using current regolith basis for now; editable."
    };
  }

  const mass = benefState.ran && Number.isFinite(Number(benefState.mFeed)) ? Number(benefState.mFeed) : fallbackFeed;
  return {
    source,
    mass,
    label: "unbeneficiated regolith feed",
    note: benefState.ran
      ? `Imported original Part 2 feed mass (${mass.toFixed(3)} g). Editable before run.`
      : "Using current regolith settings basis. Editable before run."
  };
}

function importVacuumRegolithMassFromSelection(){
  if (!pyro_regolithChargeMass) return;
  const mode = pyro_feedMode ? pyro_feedMode.value : "waste";
  const imported = getVacuumRegolithImport();
  if (pyro_regolithSourceNote) pyro_regolithSourceNote.textContent = imported.note;
  if (mode !== "waste") {
    pyro_regolithChargeMass.disabled = false;
    pyro_regolithChargeMass.value = Number.isFinite(imported.mass) ? imported.mass.toFixed(3) : "0.000";
  }
}

function updateVacuumFeedModeUI(){
  const mode = pyro_feedMode ? pyro_feedMode.value : "waste";
  const defaultWasteWet = getCurrentWasteWetMassDefault();

  if (pyro_mixWasteMass) {
    if (mode === "regolith") {
      // Regolith-only mode: waste feedstock is inactive and fixed at zero.
      pyro_mixWasteMass.value = "0.000";
      pyro_mixWasteMass.disabled = true;
    } else {
      // Waste-only and mixture modes: waste feedstock is active and editable.
      pyro_mixWasteMass.disabled = false;
      if (!(Number(pyro_mixWasteMass.value) > 0)) {
        pyro_mixWasteMass.value = Number.isFinite(defaultWasteWet) ? defaultWasteWet.toFixed(3) : "0.000";
      }
    }
  }

  if (pyro_regolithSource) {
    pyro_regolithSource.disabled = mode === "waste";
  }

  if (pyro_regolithChargeMass) {
    if (mode === "waste") {
      // Waste-only mode: regolith is inactive and fixed at zero.
      pyro_regolithChargeMass.value = "0.000";
      pyro_regolithChargeMass.disabled = true;
      if (pyro_regolithSourceNote) pyro_regolithSourceNote.textContent = "Regolith is not included in waste-only mode.";
    } else {
      // Regolith-only and mixture modes: import a Part 2 value, then keep it editable.
      pyro_regolithChargeMass.disabled = false;
      const imported = getVacuumRegolithImport();
      if (pyro_regolithSourceNote) pyro_regolithSourceNote.textContent = imported.note;
      if (!(Number(pyro_regolithChargeMass.value) > 0)) {
        pyro_regolithChargeMass.value = Number.isFinite(imported.mass) ? imported.mass.toFixed(3) : "0.000";
      }
    }
  }
}

