    var presetKey=(byId('lrc_sci_preset')||{}).value || 'mixed';
    var pnote=(presets[presetKey]||{}).note || 'Custom measured polymer';
    setText('lrc_sci_out', [
      '================ SCIENTIFIC POLYMER PYROLYSIS MODEL ================',
      'Preset / basis: '+pnote,
      'As-loaded feed:                         '+fmt(feed,3)+' g',
      'Moisture/pre-loss:                      '+fmt(waterMass,3)+' g',
      'Inert/ash/filler:                       '+fmt(inertMass,3)+' g',
      'Dry reactive polymer basis:             '+fmt(dry,3)+' g',
      '',
      'Temperature program:',
      '- Ramp: '+fmt(T0,1)+' -> '+fmt(Tset,1)+' Â°C at '+fmt(ramp,2)+' Â°C/min = '+fmt(rampSec/60,1)+' min',
      '- Hold: '+fmt(holdMin,1)+' min',
      '- Active programmed time: '+fmt(activeHr,3)+' hr | '+fit,
      '- Peak sample setpoint: '+fmt(peak,1)+' Â°C | time >=500 Â°C: '+fmt(t500/60,1)+' min | time >=700 Â°C: '+fmt(t700/60,1)+' min',
      '',
      'Kinetics:',
      '- A = '+A.toExponential(3)+' s^-1 | Ea = '+fmt(Ea/1000,2)+' kJ/mol | order n = '+fmt(order,2),
      '- Vacuum pressure = '+fmt(pPa,3)+' Pa | pressure severity factor = '+fmt(pressureSeverity,3),
      '- Arrhenius severity integral â«k(T)dt = '+fmt(integral,5),
      '- Final conversion alpha = '+fmt(alpha,6)+' ('+fmt(alpha*100,3)+'%)',
      '',
      'Normalized primary product yields on reacted dry polymer:',
      '- Char/solid precursor: '+fmt(yChar,4)+' | condensables: '+fmt(yCond,4)+' | permanent gas: '+fmt(yGas,4),
      '',
      'Mass-balanced outputs:',
      '- Recovered solid/residue = '+fmt(recoveredSolid,3)+' g  (char recovered + unconverted polymer + inert/filler)',
      '-   of which recovered fixed carbon in char = '+fmt(recoveredCarbon,3)+' g',
      '- Captured condensate/liquid = '+fmt(condensate,3)+' g',
      '- Permanent gas + uncaptured condensable carryover = '+fmt(gas,3)+' g',
      '- Sublimed/pre-loss water or volatiles = '+fmt(waterMass,3)+' g',
      '- Solid handling loss = '+fmt(handlingLoss,3)+' g',
      '- Mass balance check, outputs/feed = '+fmt(massOut,3)+' / '+fmt(feed,3)+' g  (closure '+fmt(feed>0?100*massOut/feed:0,2)+'%)',
      '',
      'Energy estimate:',
