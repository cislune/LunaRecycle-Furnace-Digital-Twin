`Preset: Custom (manual inputs)
Wet input mass:               ${mWet.toFixed(3)} g
Inert fraction removed:       ${inert.toFixed(3)} (removed mass: ${mInertRemoved.toFixed(3)} g)
Moisture (reactive basis):    ${(moist*100).toFixed(2)} wt% (removed mass: ${mMoistRemoved.toFixed(3)} g)
Dry reactive mass used:       ${Number(massInput.value).toFixed(3)} g`;
        return;
      }

      const p = PRESETS[key];
