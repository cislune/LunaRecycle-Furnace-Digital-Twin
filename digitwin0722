    function simulateOutageThermal(opts, outage){
      const Rgas = 8.314462618;
      const dt = Math.max(0.1, Number(opts.dt || 1));
      const preliminary = mantleHeatDuty(opts.pyroTemp, opts, 0, 0);
      const nominalRampSec = Math.max(dt, Number(preliminary.heatupSec || dt));
      const nominalRampRate = Math.max(0, (opts.pyroTemp - opts.T0) / nominalRampSec); // C/s
      const outageStart = Math.max(0, Number(outage.start || 0));
      const outageDuration = Math.max(0, Number(outage.duration || 0));
      const outageEnd = outageStart + outageDuration;
      const recoveryDelay = Math.max(0, Number(outage.recoveryDelay || 0));
      const backupFrac = clamp(Number(outage.backupFrac || 0), 0, 1);
      const coolingRate = Math.max(0, Number(outage.coolRateCmin || 0)) / 60; // C/s
      const extendedTotalSec = nominalRampSec + opts.pyroHoldSec + outageDuration + recoveryDelay;

      let alpha = 0;
      let Tc = Number(opts.T0);
      let Tpeak = Tc;
      let t500 = 0;
      let t700 = 0;
      let previousT = Tc;

      for (let t=0; t<extendedTotalSec; t+=dt){
        const inOutage = t >= outageStart && t < outageEnd;
        const inRecoveryDelay = t >= outageEnd && t < outageEnd + recoveryDelay;

        if (inOutage){
          // Backup heat offsets the same fraction of the measured full-outage cooling.
          Tc = Math.max(opts.T0, previousT - coolingRate * (1 - backupFrac) * dt);
        } else if (inRecoveryDelay){
          Tc = previousT;
        } else {
          // Resume nominal mantle-furnace heating toward the selected setpoint.
          Tc = Math.min(opts.pyroTemp, previousT + nominalRampRate * dt);
        }

        previousT = Tc;
        Tpeak = Math.max(Tpeak, Tc);
        if (Tc >= 500) t500 += dt;
        if (Tc >= 700) t700 += dt;

        const Tk = Tc + 273.15;
        const k = Math.max(0, Number(opts.A1 || 0)) * Math.exp(-Number(opts.Ea || 0)/(Rgas*Tk));
        alpha = 1 - (1-alpha)*Math.exp(-k*dt);
        alpha = clamp(alpha, 0, 0.999999);
      }
      return { alpha, Tpeak, t500, t700, totalTime:extendedTotalSec, rampSec:nominalRampSec };
    }

    function runOutageSimulation(){
      try {
        refreshPart4ComputedTimes();
        const opts = getInputsForRun();
        if (!(opts.totalCharge > 0)) throw new Error("Dry vacuum-process basis must be greater than 0 g after moisture/LOI removal.");

        const timing = getOutageCycleTiming();
        const pct = clamp(Number(p4_pctCycle.value || 0), 0, 100);
        const start = p4_lockToPct.checked
          ? timing.totalSec * pct / 100
          : Math.max(0, Number(p4_tStart.value || 0));
        const duration = Math.max(0, Number(p4_tDur.value || 0));
        const backupFrac = clamp(Number(p4_backupPct.value || 0)/100, 0, 1);
        const coolRateCmin = Math.max(0, Number(p4_coolMult.value || 0));
        const recoveryDelay = Math.max(0, Number(p4_recoveryDeratePct.value || 0));

        const nominal = simulatePyrolysisWithThermal(opts, null);
        const thermal = simulateOutageThermal(opts, {start, duration, backupFrac, coolRateCmin, recoveryDelay});
        const nominalAlpha = clamp(nominal.alpha * opts.vpSeverity, 0, 0.999999);
        const outageAlpha = clamp(thermal.alpha * opts.vpSeverity, 0, 0.999999);

        let organicRemaining = opts.organicDry;
        let lowVol=0, highVol=0, fracLiquid=0, fracGas=0;
        const volatilePool = opts.organicDry * (opts.yCond + opts.yGas);
        if (opts.seq === "fractionation_only" || opts.seq === "both"){
          lowVol = Math.min(organicRemaining, volatilePool * opts.vfLow);
          organicRemaining -= lowVol;
          highVol = Math.min(organicRemaining, volatilePool * opts.vfHigh);
          organicRemaining -= highVol;
          fracLiquid = lowVol*opts.vfLowLiq + highVol*opts.vfHighLiq;
          fracGas = lowVol*(1-opts.vfLowLiq) + highVol*(1-opts.vfHighLiq);
        }

        let pyChar=organicRemaining, pyCond=0, pyGas=0, reacted=0;
        if (opts.seq === "pyrolysis_only" || opts.seq === "both"){
          reacted = organicRemaining * outageAlpha;
          pyChar = reacted * opts.yChar + (organicRemaining - reacted);
          pyCond = reacted * opts.yCond;
          pyGas = reacted * opts.yGas;
        }

        const recoveredChar = pyChar * opts.solidRecovery;
        const moistureWater = Math.max(0, opts.totalWaterRemoved);
        const totalCondensate = moistureWater + fracLiquid + pyCond;
        const totalGas = fracGas + pyGas;
        const solidsTotal = recoveredChar + opts.regolithMass;
        const inputBasis = opts.totalDryBasis + moistureWater;
        const outputSum = solidsTotal + totalCondensate + totalGas;

        outageState.ran = true;
        outageState.mChar = recoveredChar;
        outageState.alpha = outageAlpha;
        outageState.mCond = totalCondensate;
        outageState.mGas = totalGas;
        outageState.Tpeak = thermal.Tpeak;
        outageState.t500 = thermal.t500;
        outageState.t700 = thermal.t700;

        const alphaLossPct = nominalAlpha > 0 ? 100*(nominalAlpha-outageAlpha)/nominalAlpha : 0;
        p4_out.textContent = `POWER-OUTAGE PYROLYSIS â CALCULATED RESULTS

Key inputs for reference
  Feedstock:                              ${opts.feedstockName}
  Mantle-furnace setpoint [C]:            ${opts.pyroTemp.toFixed(2)}
  Planned mantle-furnace cycle [s]:       ${timing.totalSec.toFixed(1)}
  Outage start [s]:                       ${start.toFixed(1)}
  Outage duration [s]:                    ${duration.toFixed(1)}
  Backup heating during outage [%]:       ${(100*backupFrac).toFixed(2)}
  Measured cooling rate [C/min]:          ${coolRateCmin.toFixed(2)}
  Recovery delay [s]:                     ${recoveryDelay.toFixed(1)}

Thermal and conversion response
  Nominal conversion alpha [-]:           ${nominalAlpha.toFixed(6)}
  Outage-adjusted conversion alpha [-]:   ${outageAlpha.toFixed(6)}
  Relative conversion loss [%]:           ${alphaLossPct.toFixed(3)}
  Peak temperature [C]:                   ${thermal.Tpeak.toFixed(2)}
  Time at or above 500 C [s]:             ${thermal.t500.toFixed(1)}
  Time at or above 700 C [s]:             ${thermal.t700.toFixed(1)}
  Outage-adjusted cycle duration [s]:      ${thermal.totalTime.toFixed(1)}

Outage-adjusted product streams
  Recovered organic solid / char [g]:     ${recoveredChar.toFixed(6)}
  Total condensable liquid [g]:           ${totalCondensate.toFixed(6)}
  Gas / vapor [g]:                        ${totalGas.toFixed(6)}
  Dry regolith / mineral residue [g]:     ${opts.regolithMass.toFixed(6)}
  Total recovered solids [g]:             ${solidsTotal.toFixed(6)}

Mass-balance check
  As-loaded process basis [g]:            ${inputBasis.toFixed(6)}
  Calculated output sum [g]:              ${outputSum.toFixed(6)}
  Residual [g]:                           ${(inputBasis-outputSum).toExponential(3)}`;

        refreshCharToPart2();
        refreshPart3GatePreview();
      } catch (error) {
        p4_out.textContent = `ERROR: ${error && error.message ? error.message : String(error)}`;
      }
    }

