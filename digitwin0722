    if(ysum<=0){ yChar=0; yCond=0; yGas=1; ysum=1; }
    yChar/=ysum; yCond/=ysum; yGas/=ysum;
    var condEff=clamp(num('lrc_sci_condEff'),0,1);
    var solidRecovery=clamp(num('lrc_sci_solidRecovery'),0,1);
    var fixedC=clamp(num('lrc_sci_fixedC')/100,0,1);
    var reacted=dry*alpha;
    var unreacted=dry-reacted;
    var primaryChar=reacted*yChar;
    var recoveredSolid=primaryChar*solidRecovery + unreacted + inertMass;
    var recoveredCarbon=primaryChar*solidRecovery*fixedC;
    var condensate=reacted*yCond*condEff;
