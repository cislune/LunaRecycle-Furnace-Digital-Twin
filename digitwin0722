      background-size: auto, auto, auto, auto, auto, auto, cover;
      background-position: center;
      background-attachment: fixed;
      background-repeat: no-repeat;
    }

    header{
      position: sticky;
      top:0;
      z-index: 10;
      padding: 18px 16px;
      background: rgba(6,18,34,0.90);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }

.topbar{
  width: 100%;
  padding: 16px 40px;
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap: 14px;
  position: relative;
  z-index: 1;
}

.brand{
  display:flex;
  flex-direction:column;
  gap: 4px;
  min-width: 0;
}
    .brandName{
      font-size: 12px;
      font-weight: 900;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(233,238,245,0.85);
      line-height: 1;
      white-space: nowrap;
      overflow:hidden;
      text-overflow: ellipsis;
    }

    h1{
      margin:0;
      font-size: 22px;
      font-weight: 900;
      letter-spacing: 0.2px;
      line-height: 1.1;
    }


    .brandCaption{
      margin-top: 3px;
      max-width: 1120px;
      color: rgba(233,238,245,0.72);
      font-size: 12px;
      line-height: 1.4;
    }

    .badge{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding: 7px 12px;
      border-radius: 999px;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.10);
      color: rgba(233,238,245,0.78);
      font-size: 12px;
      white-space: nowrap;
    }
    
    /* =========================
   Top-level section tabs
   ========================= */
.appTabs{
  display:flex;
  align-items:center;
  gap: 10px;
  flex-wrap: wrap;
  margin-top: 14px;
}

.appTab{
  width: auto;
  padding: 10px 16px;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,0.12);
  background: rgba(255,255,255,0.06);
  color: rgba(233,238,245,0.86);
  font-size: 12px;
  font-weight: 900;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 140ms ease, transform 140ms ease, border-color 140ms ease;
}

.appTab:hover{
  background: rgba(255,255,255,0.09);
  transform: translateY(-1px);
}

.appTab.isActive{
  border-color: rgba(180,120,255,0.62);
  background: rgba(180,120,255,0.18);
}

@media (max-width: 920px){
  .appTabs{ justify-content:flex-start; }
}

main{
  width: 100%;
  max-width: 1820px;
  margin: 0 auto;
  padding: 26px 40px 44px;
  display: block;
  position: relative;
  z-index: 1;
}

    .card{
      background: var(--panel);
      border: 1px solid var(--stroke);
      border-radius: var(--r);
      box-shadow: var(--shadow);
      overflow:hidden;
    }

    .cardHeader{
      padding: 18px 18px 14px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap: 12px;
    }

    .cardHeader h2{
      margin:0;
      font-size: 18px;
      font-weight: 900;
      letter-spacing: 0.2px;
    }

    .desc{
      margin-top: 10px;
      color: var(--muted);
      font-size: 12.5px;
      line-height: 1.45;
      max-width: 78ch;
    }

    .content{ padding: 18px; }

    .grid2{
      display:grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }

    .grid3{
      display:grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 14px;
    }

    @media (max-width: 920px){
      .grid2{ grid-template-columns: 1fr; }
      .grid3{ grid-template-columns: 1fr; }
      .topbar{ flex-direction: column; align-items:flex-start; }
      .badge{ white-space: normal; }
    }

    label{
      display:block;
      font-size: 12px;
      color: rgba(233,238,245,0.88);
      margin-bottom: 6px;
    }

    input, select, button, textarea{
      width:100%;
      padding: 11px 11px;
      border-radius: 12px;
      border: 1px solid var(--stroke2);
      background: rgba(255,255,255,0.07);
      color: var(--text);
      font-size: 14px;
      outline: none;
      transition: border-color 120ms ease, box-shadow 120ms ease, background 120ms ease, opacity 120ms ease;
    }

    input:focus, select:focus, textarea:focus{
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(180,120,255,0.18);
      background: rgba(255,255,255,0.08);
    }

    input:disabled{ opacity: 0.7; cursor: not-allowed; }

    .selectWrap{ position: relative; }
    .selectWrap select{
      appearance: none;
      -webkit-appearance: none;
      padding-right: 40px;
      cursor: pointer;
    }
    .selectWrap:after{
      content:"";
      position:absolute;
      right: 14px;
      top: 50%;
      width: 10px;
      height: 10px;
      border-right: 2px solid rgba(233,238,245,0.75);
      border-bottom: 2px solid rgba(233,238,245,0.75);
      transform: translateY(-60%) rotate(45deg);
      pointer-events:none;
      opacity: 0.9;
    }

    button{
      cursor:pointer;
      font-weight: 900;
      background: linear-gradient(180deg, rgba(180,120,255,0.50), rgba(180,120,255,0.24));
      border-color: rgba(180,120,255,0.62);
    }
    button:hover{
      background: linear-gradient(180deg, rgba(180,120,255,0.60), rgba(180,120,255,0.30));
    }

    pre{
      margin:0;
      background: rgba(0,0,0,0.48);
      border: 1px solid rgba(255,255,255,0.10);
      padding: 14px;
      border-radius: 12px;
      white-space: pre-wrap;
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      font-size: 12px;
      line-height: 1.45;
    }

    textarea{
      min-height: 170px;
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      font-size: 12px;
      line-height: 1.35;
      white-space: pre;
    }

    details{
      border-radius: var(--r);
      border: 1px solid rgba(255,255,255,0.10);
      background: rgba(255,255,255,0.04);
      overflow: hidden;
      margin-bottom: 18px;
    }

    summary{
      list-style:none;
      cursor:pointer;
      padding: 16px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap: 12px;
      user-select:none;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    summary::-webkit-details-marker{ display:none; }

    .sumLeft{
      display:flex;
      flex-direction:column;
      gap: 5px;
    }
    .sumTitle{
      font-weight: 900;
      font-size: 14px;
      letter-spacing: 0.2px;
    }
    .sumSub{
      font-size: 12px;
      color: var(--muted);
      line-height: 1.35;
      max-width: 92ch;
    }
    .chev{
      width: 10px;
      height: 10px;
      border-right: 2px solid rgba(233,238,245,0.70);
      border-bottom: 2px solid rgba(233,238,245,0.70);
      transform: rotate(45deg);
      transition: transform 160ms ease;
      opacity: 0.9;
      flex: 0 0 auto;
    }
    details[open] .chev{ transform: rotate(225deg); }

    .inner{ padding: 16px; }

    .pillRow{
      display:flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-top: 8px;
    }
    .pill{
      padding: 6px 11px;
      border-radius: 999px;
      font-size: 12px;
      border: 1px solid rgba(255,255,255,0.12);
      background: rgba(255,255,255,0.06);
      color: rgba(233,238,245,0.85);
    }

    .mini{
      font-size:12px;
      color: var(--muted);
      margin-top: 8px;
      line-height: 1.35;
    }

    .successPill{
      padding: 6px 11px;
      border-radius: 999px;
      font-size: 12px;
      border: 1px solid rgba(124,255,124,0.20);
      background: rgba(124,255,124,0.10);
      color: rgba(233,238,245,0.92);
      white-space: nowrap;
    }

    .warnPill{
      padding: 6px 11px;
      border-radius: 999px;
      font-size: 12px;
      border: 1px solid rgba(255,190,80,0.22);
      background: rgba(255,190,80,0.12);
      color: rgba(233,238,245,0.92);
      white-space: nowrap;
    }

    .hide { display:none; }

    .sectionDivider{
      text-align:center;
      color: rgba(233,238,245,0.78);
      padding: 10px 0 2px;
      font-weight: 900;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      font-size: 11px;
      opacity: 0.9;
    }

    .sectionDividerTight{
      text-align:center;
      color: rgba(233,238,245,0.78);
      padding: 4px 0 0;
      margin: 0;
      font-weight: 900;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      font-size: 11px;
      opacity: 0.9;
    }

    a.inlineLink{
      color: rgba(210, 180, 255, 0.95);
      text-decoration: none;
      border-bottom: 1px solid rgba(210, 180, 255, 0.35);
    }
    a.inlineLink:hover{
      border-bottom-color: rgba(210, 180, 255, 0.75);
    }

    .fullBtn{ width:100%; display:block; }
    .centerRow{ display:flex; justify-content:center; align-items:center; margin-top:14px; }

    .checkRow{
      display:flex;
      align-items:flex-start;
      gap:10px;
      margin-top: 10px;
      padding: 10px 12px;
      border-radius: 12px;
      border: 1px solid rgba(255,255,255,0.10);
      background: rgba(255,255,255,0.04);
    }
    .checkRow input[type="checkbox"]{
      width: 18px;
      height: 18px;
      margin-top: 2px;
      padding: 0;
      border-radius: 6px;
      accent-color: rgba(180,120,255,0.9);
    }
    .checkRow .checkText{
      font-size: 12.5px;
      color: rgba(233,238,245,0.86);
      line-height: 1.35;
    }

    .btnRow{
      display:flex;
      gap: 12px;
      margin-top: 14px;
    }
    @media (max-width: 920px){
      .btnRow{ flex-direction: column; }
    }

    /* =========================
       Equation system
       ========================= */
    .eqCaption{
      margin-top: 10px;
      font-size: 12px;
      color: rgba(233,238,245,0.78);
      line-height: 1.35;
    }

    .eqBox{
      margin-top: 8px;
      padding: 12px;
      border-radius: 14px;
      border: 1px solid var(--eqStroke);
      background: var(--eqBg);
      overflow: hidden;

      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(260px, 300px);
      gap: 10px;
      align-items: stretch;
    }

    .eqBox .eqMath{
      min-height: 120px;
      padding: 10px;
      border-radius: 12px;
      border: 1px solid rgba(255,255,255,0.10);
      background: rgba(0,0,0,0.38);     /* darker inner panel */
      display:flex;
      align-items:center;
      justify-content:center;
      text-align:center;
      overflow:auto;
    }

    /* Default equation size (unchanged) */
    .katex{
      color: rgba(233,238,245,0.94);
      font-size: 1.28em;
    }
    .katex-display{ margin: 0; }

    /* (changed) Smaller equations ONLY for feedstock + kinetics boxes */
    .eqBox.eqFeedstock .katex,
    .eqBox.eqKinetics .katex{
      font-size: 1.16em;
    }

    /* (changed) Key styling: sheer black box + corner title + prettier font */
    .eqBox .eqKey{
      position: relative;
      border-radius: 12px;
      border: 1px solid var(--eqKeyStroke);
      background: var(--eqKeyBg);
      padding: 10px 12px 10px;
      box-shadow:
        inset 0 0 0 1px rgba(255,255,255,0.05),
        0 16px 28px rgba(0,0,0,0.60);
      overflow: hidden;
    }

    .eqKeyTitle{
      position: absolute;
      top: 8px;
      left: 10px;
      font-size: 10px;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.55);
      font-weight: 650;
    }

    .eqKeyList{
      margin-top: 22px;
      font-size: 12px;
      line-height: 1.35;
      font-family: "IBM Plex Serif", "STIX Two Text", "Georgia", "Times New Roman", serif;
      color: rgba(233,238,245,0.88);
    }

    .eqKeyList > div{
      white-space: normal;
      overflow: visible;
      text-overflow: clip;
      margin-bottom: 4px;
    }

    .eqKeyList .k{
      display:inline-flex;
      align-items:center;
      min-width: 56px;
      margin-right: 8px;
      font-weight: 700;
      color: rgba(255,255,255,0.92);
    }

    .eqKeyList .k .katex{
      font-size: 1.0em;
    }

    @media (max-width: 920px){
      .eqBox{ grid-template-columns: 1fr; }
      .eqKeyList > div{ white-space: normal; }
    }
    /* =========================
   Left side tab navigation
   ========================= */
.sideTabs{
  position: fixed;
  left: 18px;
  top: 148px; /* below header + section tabs */
  z-index: 20;
  width: 285px;
  pointer-events: none;
}

.sideTabsInner{
  pointer-events: auto;
  background: rgba(6,18,34,0.86);
  border: 1px solid rgba(255,255,255,0.10);
  border-radius: 16px;
  backdrop-filter: blur(12px);
  box-shadow: 0 14px 36px rgba(0,0,0,0.42);
  padding: 14px;
}

.sideTabsTitle{
  font-size: 10px;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: rgba(233,238,245,0.72);
  font-weight: 800;
  margin: 2px 6px 10px;
}

.sideTab{
  width: 100%;
  text-align: left;
  padding: 12px 14px;
  border-radius: 12px;
  border: 1px solid rgba(255,255,255,0.10);
  background: rgba(255,255,255,0.05);
  color: rgba(233,238,245,0.86);
  font-size: 13px;
  font-weight: 800;
  line-height: 1.25;
  cursor: pointer;
  margin-bottom: 8px;
  transition: background 140ms ease, border-color 140ms ease, transform 140ms ease;
}

.sideTab:hover{
  background: rgba(255,255,255,0.08);
  transform: translateY(-1px);
}

.sideTab.isActive{
  border-color: rgba(180,120,255,0.62);
  background: rgba(180,120,255,0.18);
}




.organicWrap{ position: relative; }




/* =========================
   Workflow alignment fix
   ========================= */
.contentSection{
  display:none;
  width: 100%;
  max-width: 100%;
}

.contentSection.isActive{
  display:block;
}

.organicMain{
  width: 100%;
}

.organicMain > .sectionDivider,
.organicMain > .sectionDividerTight,
.organicMain > .card{
  width: 100%;
  max-width: 100%;
  margin-left: 0;
  margin-right: 0;
}

.card,
details,
.eqBox,
.grid2,
.grid3,
.content,
.inner{
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
}

.eqBox{
  grid-template-columns: minmax(0, 1fr) minmax(260px, 300px);
}

.eqBox .eqMath{
  min-width: 0;
}

@media (min-width: 1181px){
  .organicMain{
    padding-left: 325px;
    padding-right: 0;
  }
}

@media (max-width: 1180px){
  .organicMain{
    padding-left: 0;
  }
}

.organicMain > .card{
  margin-top: 0;
  margin-bottom: 24px;
}

.organicMain > .sectionDivider,
.organicMain > .sectionDividerTight{
  margin-top: 0;
  margin-bottom: 12px;
}

@media (max-width: 1180px){
  .sideTabs{ display:none; }
}
  
/* Merged regolith feed + oxide bubble spacing */
details .sectionDividerTight{
  border-top: 1px solid rgba(255,255,255,0.08);
  padding-top: 16px;
  margin-bottom: 12px;
}


/* Magnetic beneficiator concept sketch */
.magHeaderGrid{
  display:grid;
  grid-template-columns:minmax(360px,1fr) auto minmax(420px,520px);
  align-items:center;
  gap:22px;
