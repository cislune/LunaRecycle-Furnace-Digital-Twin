          lines.push(`Total dry reactive mass used:     ${blend.totalDry.toFixed(3)} g`);
          lines.push("");
          lines.push("Component mass balance:");
          for (const c of blend.components){
            if (c.mWet <= 0) continue;
            const fracDry = 100.0 * c.mDry / blend.totalDry;
            lines.push(`  ${c.name}`);
            lines.push(`    as-received: ${c.mWet.toFixed(3)} g | dry reactive: ${c.mDry.toFixed(3)} g | dry-basis share: ${fracDry.toFixed(2)} wt%`);
