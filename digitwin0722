<!DOCTYPE html>
<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="utf-8"/>
<title>Cislune LunaRecycle Digital Twin - Magnetic Beneficiation, Pyrolysis, Carbothermal Reduction</title>
<meta content="width=device-width, initial-scale=1" name="viewport"/>
<link href="https://cdn.jsdelivr.net/npm/katex@0.16.10/dist/katex.min.css" rel="stylesheet"/>
<script defer="" src="https://cdn.jsdelivr.net/npm/katex@0.16.10/dist/katex.min.js"></script>
<style>
    :root{
      --bg0:#071423;
      --bg1:#0b1a2a;
      --panel: rgba(255,255,255,0.06);
      --stroke: rgba(255,255,255,0.12);
      --stroke2: rgba(255,255,255,0.18);
      --text:#e9eef5;
      --muted: rgba(233,238,245,0.72);
      --shadow: 0 14px 36px rgba(0,0,0,0.42);
      --r: 16px;

      /* (changed) equation visuals */
      --eqBg: rgba(0,0,0,0.58);             /* darker equation box */
      --eqStroke: rgba(255,255,255,0.16);

      /* (changed) key box visuals */
      --eqKeyBg: rgba(0,0,0,0.78);          /* sheer black key box */
      --eqKeyStroke: rgba(255,255,255,0.16);

      --accent: rgba(180,120,255,0.70);
    }

    * { box-sizing: border-box; }
    html { background: #020611; }

    body{
      margin:0;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      color: var(--text);
      min-height: 100vh;
      position: relative;
      overflow-x: hidden;

      background:
        radial-gradient(1200px 700px at 15% 10%, rgba(140, 90, 255, 0.34), transparent 62%),
        radial-gradient(1000px 650px at 80% 20%, rgba(175, 110, 255, 0.22), transparent 58%),
        radial-gradient(900px 600px at 55% 85%, rgba(210, 140, 255, 0.14), transparent 62%),
        radial-gradient(700px 500px at 30% 70%, rgba(255, 120, 210, 0.12), transparent 60%),
        radial-gradient(900px 700px at 70% 65%, rgba(255, 210, 255, 0.10), transparent 62%),
        linear-gradient(180deg, #01040f, #040b1a 48%, #071423),
