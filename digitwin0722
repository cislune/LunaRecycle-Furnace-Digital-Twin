          massSummary.textContent = lines.join("\n");
        } catch(e){
          massSummary.textContent = `ERROR: ${e.message}`;
        }
        return;
      }

      const mWet = Number(wetMass.value);
      if (!(mWet > 0)){
        massSummary.textContent = "Wet input mass must be > 0.";
        return;
      }

      if (key === "custom"){
        setPrimaryYieldMode("custom");
        const inert = clamp(Number(customInertFrac.value || 0), 0, 0.99);
        const moist = clamp(Number(customMoistPct.value || 0) / 100.0, 0, 0.99);

        const mReactive = (1 - inert) * mWet;
        const mDry = (1 - moist) * mReactive;

        const mInertRemoved = mWet - mReactive;
        const mMoistRemoved = mReactive - mDry;

        if (customAutoNormalize.value === "yes"){
          massInput.value = String(mDry);
          massInput.disabled = true;
        } else {
          massInput.disabled = false;
        }
