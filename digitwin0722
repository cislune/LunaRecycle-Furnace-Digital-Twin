      massInput.disabled = false;
      if (pyro_mixWasteMass && (pyro_feedMode ? pyro_feedMode.value !== "mixture" : true)) pyro_mixWasteMass.value = mWet.toFixed(3);

      massSummary.textContent =
`Preset: ${p.name}
Wet input mass:               ${mWet.toFixed(3)} g
Inert fraction removed:       ${p.inertFrac}  (removed mass: ${mInertRemoved.toFixed(3)} g)
Moisture (reactive basis):    ${p.moistPct} wt% (removed mass: ${mMoistRemoved.toFixed(3)} g)
Dry reactive mass used:       ${mDry.toFixed(3)} g`;
    }

