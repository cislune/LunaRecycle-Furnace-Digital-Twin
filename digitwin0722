function updateClosestRunCarbon(value){
  const runs = loadRuns();
  const q = getFactSageQuery();
  const closest = closestRun(runs, q);
  if (!closest) throw new Error("No saved FactSage run found for the current simulant.");
  const v = (value === null || value === "") ? null : Number(value);
  if (v !== null && !(v >= 0)) throw new Error("C(graphite) input must be >= 0 g.");
  const idx = runs.findIndex(r => r.savedAt === closest.savedAt && runKey(r) === runKey(closest));
  if (idx >= 0) runs[idx].mCinput_g = v;
  saveRuns(runs);
  refreshRunsUI();
}

