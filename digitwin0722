    var rxnKJ=(reacted/1000)*dH;
    var grossKJ=(sensibleKJ+rxnKJ)/eff;
    var kWh=grossKJ/3600;
    var activeHr=totalSec/3600;
    var coolLow=num('lrc_py_coolLow')||1, coolHigh=num('lrc_py_coolHigh')||1.5;
