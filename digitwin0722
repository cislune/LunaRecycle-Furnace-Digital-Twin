    function componentDryMass(presetKey, wetMassValue){
      const p = PRESETS[presetKey];
      const mWet = Number(wetMassValue || 0);
      if (!(mWet >= 0)) throw new Error(`${p.name} blend mass must be >= 0 g.`);
      const inert = clamp(Number(p.inertFrac || 0), 0, 0.99);
      const moist = clamp(Number(p.moistPct || 0) / 100.0, 0, 0.99);
      const mReactive = (1 - inert) * mWet;
      const mDry = (1 - moist) * mReactive;
      return { key:presetKey, name:p.name, mWet, inert, moist, mReactive, mDry, preset:p };
    }

    function computeBlendFeedstock(){
      const components = [
        componentDryMass("cellulose", blend_celluloseMass ? blend_celluloseMass.value : 0),
        componentDryMass("nitrile", blend_nitrileMass ? blend_nitrileMass.value : 0),
        componentDryMass("polyolefin", blend_polyolefinMass ? blend_polyolefinMass.value : 0),
        componentDryMass("laminate", blend_laminateMass ? blend_laminateMass.value : 0)
      ];

      const totalWet = components.reduce((a,c)=>a+c.mWet, 0);
      const totalReactive = components.reduce((a,c)=>a+c.mReactive, 0);
      const totalDry = components.reduce((a,c)=>a+c.mDry, 0);

      if (!(totalWet > 0)) throw new Error("At least one mixed feedstock mass must be > 0 g.");
      if (!(totalDry > 0)) throw new Error("Mixed dry reactive mass must be > 0 g.");

      const wAvg = (field) => components.reduce((a,c)=>a + c.mDry * Number(c.preset[field]), 0) / totalDry;

      const blendA1 = wAvg("A1");
      const blendEa1 = wAvg("Ea1");
      const blendYchar = wAvg("Ychar");
      const blendYcond = wAvg("Ycond");
      const blendYgas = wAvg("Ygas");

      return { components, totalWet, totalReactive, totalDry, blendA1, blendEa1, blendYchar, blendYcond, blendYgas };
    }

    function computeDryReactiveMass(key){
