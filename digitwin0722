    function parsePsdBins(){
      const mins = Array.from(document.querySelectorAll(".psdMin"));
      const maxs = Array.from(document.querySelectorAll(".psdMax"));
      const wts = Array.from(document.querySelectorAll(".psdWt"));
      const bins = [];
      const n = Math.max(mins.length, maxs.length, wts.length);
      for (let i = 0; i < n; i++){
        const dMin = Number(mins[i] ? mins[i].value : NaN);
        const dMax = Number(maxs[i] ? maxs[i].value : NaN);
        const wt = Number(wts[i] ? wts[i].value : NaN);
        if (!Number.isFinite(dMin) || !Number.isFinite(dMax) || !Number.isFinite(wt)) continue;
        if (!(dMax > dMin) || !(wt > 0)) continue;
        const dRep = dMin <= 0 ? dMax / 2 : Math.sqrt(dMin * dMax);
        bins.push({ dMin, dMax, wt, dRep });
      }
      const total = bins.reduce((a,b)=>a + b.wt, 0);
      if (!(total > 0)) return [];
      return bins.map(b => ({ ...b, frac: b.wt / total }));
    }

        // -----------------------------------------------------------------------
    // Three parallel rotating N52-rod magnetic beneficiator.
    // Deterministic: identical inputs always produce identical outputs.
    // The magnetic-force balance is physics based. Susceptibility, vibration
    // uniformity, entrainment, and loss correlations are apparatus-calibration
    // submodels and must be fitted to replicate measurements quantitatively.
    // -----------------------------------------------------------------------
    const MU0 = 4 * Math.PI * 1e-7;
    const G0 = 9.80665;

    function smoothStep01(x){
      const y = clamp(x, 0, 1);
      return y * y * (3 - 2 * y);
    }

    function logisticFromLogRatio(ratio, sharpness=2.2){
      const r = Math.max(1e-12, ratio);
      return 1 / (1 + Math.exp(-sharpness * Math.log(r)));
    }

    function vibrationFeedState(freqHz, amplitudeMm, slotWidthCm, d50Um){
      const amplitudeM = Math.max(0, amplitudeMm) / 1000;
      const omega = 2 * Math.PI * Math.max(0, freqHz);
      const gamma = amplitudeM * omega * omega / G0; // dimensionless peak acceleration

      // Flow begins reliably once peak vibratory acceleration approaches gravity.
      const activation = smoothStep01((gamma - 0.25) / 1.25);

      // Very high acceleration promotes segregation, dusting, and nonuniform spurts.
      const overdrive = Math.max(0, gamma - 3.0);
      const overdrivePenalty = Math.exp(-0.16 * overdrive * overdrive);

      // A 30-mm-wide slot is very large relative to this PSD; width correction is
      // retained so the same formulation remains valid if geometry changes.
      const widthToParticle = (slotWidthCm * 10000) / Math.max(1, d50Um);
      const archingSafety = smoothStep01((widthToParticle - 6) / 20);
      const uniformity = clamp((0.35 + 0.65 * activation) * overdrivePenalty * archingSafety, 0.05, 1.0);
      return { gamma, activation, overdrivePenalty, archingSafety, uniformity };
    }

    function rodFieldAtParticle(Bsurface, radiusM, gapM){
      // Cylindrical/dipole falloff approximation. For engineering prediction,
      // replace with a measured B(r) curve or finite-element field map.
      const ratio = radiusM / Math.max(radiusM + gapM, 1e-9);
      const B = Bsurface * Math.pow(ratio, 3);
      const gradB = 3 * B / Math.max(radiusM + gapM, 1e-9);
      return { B, gradB };
    }

    function particleRetentionEta({dUm, B, gradB, radiusM, rpm, rho, deltaChi, loadingKgM2, contactUniformity, coverage}){
      const dM = dUm * 1e-6;
      const volume = Math.PI * Math.pow(dM, 3) / 6;
      const mass = rho * volume;
      const surfaceSpeed = 2 * Math.PI * radiusM * rpm / 60;
      const magneticForce = Math.max(0, volume * deltaChi * B * gradB / MU0);
      const gravityForce = mass * G0;
      const centrifugalForce = mass * surfaceSpeed * surfaceSpeed / Math.max(radiusM, 1e-9);
      const detachingForce = gravityForce + centrifugalForce;
      const forceRatio = magneticForce / Math.max(detachingForce, 1e-18);
      const forceRetention = logisticFromLogRatio(forceRatio, 2.25);

      // Surface loading attenuates field/contact for upper particle layers.
      // lambda50 is an apparatus calibration scale, not a universal constant.
      const lambda50 = 0.65; // kg/m2
      const loadingFactor = 1 / (1 + Math.pow(loadingKgM2 / lambda50, 1.35));
      const eta = clamp(forceRetention * loadingFactor * contactUniformity * coverage, 0, 0.995);
      return { eta, magneticForce, detachingForce, forceRatio, surfaceSpeed, loadingFactor };
    }

    function weightedThreeRodCapture(params){
      const usePsd = document.getElementById('mb_psdMode')?.value === 'psd';
      const bins = usePsd ? parsePsdBins() : [];
      const activeBins = (!usePsd || bins.length === 0)
        ? [{dMin: params.d50, dMax: params.d50, dRep: params.d50, frac: 1}]
        : bins;

      let etaWeighted = 0;
      let forceRatioWeighted = 0;
      let loadFactorWeighted = 0;
      const lines = [];
      for (const b of activeBins){
        const r = particleRetentionEta({...params, dUm: b.dRep});
        etaWeighted += b.frac * r.eta;
        forceRatioWeighted += b.frac * r.forceRatio;
        loadFactorWeighted += b.frac * r.loadingFactor;
        lines.push(`    ${b.dMin.toFixed(1)}-${b.dMax.toFixed(1)} um | mass ${(100*b.frac).toFixed(2)}% | magnetic capture efficiency ${r.eta.toFixed(4)} | Fmag/Fdetach ${r.forceRatio.toExponential(3)}`);
      }
      return {
        mode: usePsd && bins.length ? 'psd' : 'd50',
        eta: clamp(etaWeighted, 0, 0.995),
        meanForceRatio: forceRatioWeighted,
        meanLoadingFactor: loadFactorWeighted,
        summary: `${usePsd && bins.length ? 'PSD-weighted' : 'd50'} calculation:\n${lines.join('\n')}`
      };
    }

    function runMagneticBeneficiation(){
      try {
        const num = id => Number(document.getElementById(id)?.value);
        const mFeedG = num('mb_regolithMass');
        const wMagPct = num('mb_feFeedPct');
        const Bsurface = num('mb_surfaceFieldT');
        const gapM = num('mb_gapMm') / 1000;
        const d50 = num('mb_d50um');
        const rpm = num('mb_rodRpm');
        const vibrationHz = num('mb_vibrationHz');
        const vibrationAmplitudeMm = num('mb_vibrationAmplitudeMm');
        const durationS = num('mb_runDurationS');
        const dropHeightM = num('mb_dropHeightMm') / 1000;
        const rodCount = Math.round(num('mb_rodCount'));
        const slotCount = Math.round(num('mb_funnelCount'));
        const slotLengthM = num('mb_slotLengthCm') / 100;
        const slotWidthCm = num('mb_slotWidthCm');
        const rodLengthM = num('mb_rodLengthCm') / 100;
        const rodDiameterM = num('mb_rodDiameterMm') / 1000;
        const radiusM = rodDiameterM / 2;
        const passes = Math.max(1, Math.round(num('mb_passes')));
        const entrainBase = Number(document.getElementById('mb_ganguePct')?.value ?? 0.08);

        if (!(mFeedG > 0)) throw new Error('Feed mass must be greater than 0 g.');
        if (!(wMagPct >= 0 && wMagPct <= 100)) throw new Error('Magnetic fraction must be between 0 and 100 wt%.');
        if (!(Bsurface > 0)) throw new Error('Measured rod-surface field must be greater than 0 T.');
        if (!(radiusM > 0 && rodLengthM > 0)) throw new Error('Rod diameter and active length must be greater than 0.');
        if (!(rpm > 0)) throw new Error('Rod RPM must be greater than 0.');
        if (!(durationS > 0)) throw new Error('Run duration must be greater than 0 s.');
        if (!(rodCount === 3 && slotCount === 3)) throw new Error('This model is fixed to three rods and three funnel openings.');

        const mFeedKg = mFeedG / 1000;
        const field = rodFieldAtParticle(Bsurface, radiusM, gapM);
        const surfaceSpeed = 2 * Math.PI * radiusM * rpm / 60;
        const revolutions = rpm * durationS / 60;
        const coverage = clamp(1 - Math.exp(-1.6 * revolutions), 0, 1);
        const sweptArea = rodCount * rodLengthM * surfaceSpeed * durationS;
        const loadingKgM2 = mFeedKg / Math.max(sweptArea, 1e-12);
        const feedRateGS = mFeedG / durationS;
        const feedPerSlotGS = feedRateGS / slotCount;

        const vib = vibrationFeedState(vibrationHz, vibrationAmplitudeMm, slotWidthCm, d50);

        // Effective magnetic susceptibility contrast. This is a scenario/calibration
        // value for Fe/Ti-bearing magnetic grains, not a universal LHS-1 constant.
        const deltaChiMag = 0.35;
        const rhoMag = 4800; // kg/m3, effective Fe/Ti-bearing phase density
        const magCalc = weightedThreeRodCapture({
          d50, B: field.B, gradB: field.gradB, radiusM, rpm, rho: rhoMag,
          deltaChi: deltaChiMag, loadingKgM2,
          contactUniformity: vib.uniformity,
          coverage
        });
        const etaMagOnePass = magCalc.eta;
        const etaMag = clamp(1 - Math.pow(1 - etaMagOnePass, passes), 0, 0.999);

        // Weak gangue capture uses a much smaller susceptibility contrast and an
        // empirical mechanical-adhesion contribution that increases for fine feed.
        const rhoGangue = 2900;
        const deltaChiGangue = 0.003;
        const gangueCalc = weightedThreeRodCapture({
          d50, B: field.B, gradB: field.gradB, radiusM, rpm, rho: rhoGangue,
          deltaChi: deltaChiGangue, loadingKgM2,
          contactUniformity: vib.uniformity,
          coverage
        });
        const fineAdhesion = Math.exp(-0.0045 * d50);
        const etaGangueOnePass = clamp(gangueCalc.eta + entrainBase * fineAdhesion * vib.uniformity, 0, 0.45);
        const etaGangue = clamp(1 - Math.pow(1 - etaGangueOnePass, passes), 0, 0.75);

        // Loss model: dust/spillage/wall adhesion. Terms are deterministic and
        // bounded; calibrate coefficients from total recovered mass in actual runs.
        const dropPenalty = 0.012 * clamp(dropHeightM / 0.05, 0, 3);
        const vibrationPenalty = 0.025 * (1 - vib.uniformity);
        const loadingPenalty = 0.020 * clamp(loadingKgM2 / 1.5, 0, 2);
        const rpmPenalty = 0.010 * clamp((surfaceSpeed - 0.25) / 0.50, 0, 2);
        const baseLoss = 0.008;
        const lossFrac = clamp(baseLoss + dropPenalty + vibrationPenalty + loadingPenalty + rpmPenalty, 0, 0.30);

        const wMag = wMagPct / 100;
        const recoveredFactor = 1 - lossFrac;
        const mMagAvailable = mFeedG * wMag;
        const mGangueAvailable = mFeedG * (1 - wMag);
        const mMagCaptured = mMagAvailable * recoveredFactor * etaMag;
        const mGangueCaptured = mGangueAvailable * recoveredFactor * etaGangue;
        const mMagOut = clamp(mMagCaptured + mGangueCaptured, 0, mFeedG * recoveredFactor);
        const mLost = mFeedG * lossFrac;
        const mNonMagOut = Math.max(0, mFeedG - mLost - mMagOut);
        const mMagRemaining = Math.max(0, mMagAvailable * recoveredFactor - mMagCaptured);
        const mGangueRejected = Math.max(0, mNonMagOut - mMagRemaining);

        const magRecoveryPct = mMagAvailable > 0 ? 100 * mMagCaptured / mMagAvailable : 0;
        const totalRecoveryPct = 100 * (mMagOut + mNonMagOut) / mFeedG;
        const magOutPurityPct = mMagOut > 0 ? 100 * mMagCaptured / mMagOut : 0;
        const feedUpgrade = wMagPct > 0 ? magOutPurityPct / wMagPct : 0;
        const balanceError = mFeedG - (mMagOut + mNonMagOut + mLost);

        benefState.ran = true;
        benefState.use = Boolean(document.getElementById('mb_forwardToP2')?.checked);
        benefState.stream = document.getElementById('mb_streamForTests')?.value || 'magnetic';
        benefState.mFeed = mFeedG;
        benefState.mConc = mMagOut;
        benefState.mNonMagBin = mNonMagOut;
        benefState.feFeedPct = wMagPct;
        benefState.feConcPct = magOutPurityPct;
        benefState.nonMagMagPct = mNonMagOut > 0 ? 100 * mMagRemaining / mNonMagOut : 0;
        benefState.feRichMass = mMagCaptured;
        benefState.mMagRemaining = mMagRemaining;
        benefState.mGangueEntrained = mGangueCaptured;
        benefState.mGangueRejected = mGangueRejected;
        benefState.upgrade = feedUpgrade;
        benefState.mLost = mLost;

        if (document.getElementById('mb_magRecoveryPct')) document.getElementById('mb_magRecoveryPct').value = magRecoveryPct.toFixed(3);

        document.getElementById('mb_out').textContent = `THREE-ROD N52 MAGNETIC BENEFICIATION â CALCULATED RESULTS

Key inputs for reference
  Feed mass [g]:                         ${mFeedG.toFixed(2)}
  Magnetic feed fraction [wt%]:          ${wMagPct.toFixed(2)}
  Rod-surface field [T]:                 ${Bsurface.toFixed(2)}
  Non-magnetic sheath thickness [mm]:    ${(gapM*1000).toFixed(2)}
  Rod speed [RPM]:                       ${rpm.toFixed(2)}
  Number of passes [-]:                  ${passes}

Product streams
  Magnetic concentrate [g]:            ${mMagOut.toFixed(3)}
  Non-magnetic fraction [g]:            ${mNonMagOut.toFixed(3)}
  Lost / unrecovered material [g]:      ${mLost.toFixed(3)}

Separation performance
  Magnetic recovery [%]:                ${magRecoveryPct.toFixed(2)}
  Concentrate magnetic content [wt%]:   ${magOutPurityPct.toFixed(2)}
  Upgrade factor [-]:                   ${feedUpgrade.toFixed(3)}
  Total recovered mass [%]:             ${totalRecoveryPct.toFixed(2)}

Mass-balance check
  Calculated output sum [g]:            ${(mMagOut + mNonMagOut + mLost).toFixed(3)}
  Residual [g]:                         ${balanceError.toExponential(3)}
=======================================================================`;

        syncBeneficiationToPart2();
        if (typeof syncPyroRegolithSource === 'function') syncPyroRegolithSource();
      } catch (e) {
        document.getElementById('mb_out').textContent = `ERROR: ${e.message}`;
      }
    }

