<script id="final-navigation-target-fix-script">
(function(){
  'use strict';

  function byId(id){ return document.getElementById(id); }
  function all(selector){ return Array.prototype.slice.call(document.querySelectorAll(selector)); }

  function activateMainSection(sectionId){
    var target = byId(sectionId);
    if (!target) return false;

    all('.contentSection').forEach(function(section){
      var active = section.id === sectionId;
      section.classList.toggle('isActive', active);
      section.style.display = active ? 'block' : 'none';
    });

    all('.appTab').forEach(function(tab){
      tab.classList.toggle('isActive', tab.getAttribute('data-section') === sectionId);
    });

    var sideTabs = byId('organicSideTabs');
    if (sideTabs) sideTabs.style.display = sectionId === 'organicSection' ? 'block' : 'none';
    return true;
  }

  function headerOffset(){
    var header = document.querySelector('header');
    return (header ? Math.ceil(header.getBoundingClientRect().height) : 0) + 14;
  }

  function scrollToWorkflowTarget(targetId){
    var target = byId(targetId);
    if (!target) return;
    var top = target.getBoundingClientRect().top + window.pageYOffset - headerOffset();
    window.scrollTo({ top: Math.max(0, top), behavior: 'smooth' });
  }

  function setActiveSideTab(targetId){
    all('.sideTab').forEach(function(tab){
      tab.classList.toggle('isActive', tab.getAttribute('data-target') === targetId);
    });
  }

  /* Capture clicks and apply one authoritative navigation action. */
  document.addEventListener('click', function(event){
    var appTab = event.target.closest && event.target.closest('.appTab[data-section]');
    if (appTab){
      event.preventDefault();
      event.stopImmediatePropagation();
      var sectionId = appTab.getAttribute('data-section');
      if (!activateMainSection(sectionId)) return;
      setActiveSideTab('');
      requestAnimationFrame(function(){
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
      return;
    }

    var sideTab = event.target.closest && event.target.closest('.sideTab[data-target]');
    if (sideTab){
      event.preventDefault();
      event.stopImmediatePropagation();
      var targetId = sideTab.getAttribute('data-target');
      if (!activateMainSection('organicSection')) return;
      setActiveSideTab(targetId);
      /* Wait for the nominal section to become measurable before scrolling. */
      requestAnimationFrame(function(){
        requestAnimationFrame(function(){
          scrollToWorkflowTarget(targetId);
        });
      });
    }
  }, true);

  /* Keep the highlighted workflow tab synchronized while manually scrolling. */
  var workflowIds = ['partRegolith','part2mag','part1','part2','part3','part4','part5'];
  var ticking = false;
  function syncSideTab(){
    ticking = false;
    var nominal = byId('organicSection');
    if (!nominal || getComputedStyle(nominal).display === 'none') return;
    var probe = headerOffset() + 28;
    var current = workflowIds[0];
    workflowIds.forEach(function(id){
      var el = byId(id);
      if (el && el.getBoundingClientRect().top <= probe) current = id;
    });
    setActiveSideTab(current);
  }
  window.addEventListener('scroll', function(){
    if (!ticking){
      ticking = true;
      requestAnimationFrame(syncSideTab);
    }
  }, {passive:true});

  window.addEventListener('DOMContentLoaded', function(){
    var active = document.querySelector('.appTab.isActive[data-section]');
    activateMainSection(active ? active.getAttribute('data-section') : 'organicSection');
    syncSideTab();
  });
})();
</script>

