  // Custom = editable, no overwrite
  if (!preset){
    oxideInputs.forEach(el => el.disabled = false);
    if (ox_notes) ox_notes.value = "Custom / measured oxide table.";
    updateOxideSum();
    return;
  }

  // Preset = overwrite + lock. Preset values are already normalized to 100.000 wt% for mass balance.
  // Notes preserve cases where a zero means "not separately represented" rather than physically absent.
  const put = (el, value) => {
    if (value === null || value === undefined || Number.isNaN(Number(value))) {
      el.value = "";
    } else {
      el.value = String(value);
    }
  };

  put(ox_SiO2, preset.SiO2);
  put(ox_Al2O3, preset.Al2O3);
  put(ox_FeO, preset.FeO);
  put(ox_Fe2O3, preset.Fe2O3);
  put(ox_CaO, preset.CaO);
