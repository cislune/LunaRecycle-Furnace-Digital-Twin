      '- Effective pyrolysis heat = '+fmt(rxnKJ,2)+' kJ',
      '- Gross heat input at '+fmt(eff*100,1)+'% efficiency = '+fmt(grossKJ,2)+' kJ = '+fmt(kWh,4)+' kWh',
      '',
      'Operations wrapper:',
      '- Active run from scientific ramp+hold: '+fmt(activeHr,2)+' hr',
      '- Cool-down envelope: '+fmt(coolLow,2)+'-'+fmt(coolHigh,2)+' hr',
      '- Cleanup/reset envelope: '+fmt(resetLow,2)+'-'+fmt(resetHigh,2)+' hr',
      '- Full cycle including reset: '+fmt(cycleLow,2)+'-'+fmt(cycleHigh,2)+' hr',
      '- Fume hood / ventilated containment required for active pyrolysis vapors, condensables, and off-gas.'
    ].join('\n'));
    window.lrcScientificPyrolysisLast = {alpha:alpha, yChar:yChar, yCond:yCond, yGas:yGas, recoveredSolid:recoveredSolid, condensate:condensate, gas:gas, fixedCarbon:recoveredCarbon, activeHr:activeHr};
  }

  function copyScientificToCycle(){
