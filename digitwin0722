    ? { mLoaded:0, loiPct: Number(p2_loiPct ? p2_loiPct.value : 0), mWaterRemoved:0, mDry:0 }
    : getRegolithVacuumBalance(enteredRegolithLoaded);

  return {
    key, mode, seq,
    regolithSource: pyro_regolithSource ? pyro_regolithSource.value : "unbeneficiated",
    regolithSourceLabel: getVacuumRegolithImport().label,
    feedstockName: currentFeedstockLabel(),
    organicWet: organicBalance.mWet,
    organicReactive: organicBalance.mReactive,
    organicDry: organicBalance.mDry,
    organicInertRemoved: organicBalance.mInertRemoved,
    organicWaterRemoved: organicBalance.mWaterRemoved,
    organicBalanceNote: organicBalance.note,
    regolithLoaded: regolithBalance.mLoaded,
    regolithWaterRemoved: regolithBalance.mWaterRemoved,
    regolithMass: regolithBalance.mDry,
    regolithLoiPct: regolithBalance.loiPct,
    totalWetCharge: organicBalance.mWet + regolithBalance.mLoaded,
    totalWaterRemoved: organicBalance.mWaterRemoved + regolithBalance.mWaterRemoved,
    totalDryBasis: organicBalance.mDry + regolithBalance.mDry,
    totalCharge: organicBalance.mDry + regolithBalance.mDry,
    A1: Number(A1input ? A1input.value : 5e9),
    Ea: Number(Ea1input ? Ea1input.value : 190000),
    dt: Math.max(0.1, Number(dtInput ? dtInput.value : 1)),
    T0: Number(T0input ? T0input.value : 25),
    pyroTemp: Number(mfPyroTempInput ? mfPyroTempInput.value : 700),
    pyroHoldSec: 60*Math.max(0, Number(mfPyroHoldInput ? mfPyroHoldInput.value : 60)),
    furnacePowerW: Math.max(1, Number(mfPowerInput ? mfPowerInput.value : 1200)),
    thermalEff: clamp(Number(mfEffInput ? mfEffInput.value : 0.65),0.01,1),
    heatLossMult: Math.max(1, Number(mfLossInput ? mfLossInput.value : 1.25)),
    Cfurn: Math.max(0, Number(CfurnInput ? CfurnInput.value : 18000)),
    Cload: Math.max(0, Number(CloadInput ? CloadInput.value : 2500)),
    pyroDH: Math.max(0, Number(mfPyroDHInput ? mfPyroDHInput.value : 600)),
    yChar: yChar/ySum,
    yCond: yCond/ySum,
    yGas: yGas/ySum,
    ySumRaw: yChar + yCond + yGas,
    vfLow: clamp(Number(vf_lowVolFrac ? vf_lowVolFrac.value : 0.18),0,1),
    vfLowLiq: clamp(Number(vf_lowLiqCapture ? vf_lowLiqCapture.value : 0.85),0,1),
