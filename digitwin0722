<script>
(function(){
  function isEditableNumericInput(el){
    return el && el.tagName === 'INPUT' && el.type === 'number' && !el.disabled && !el.readOnly;
  }
  function sanitizeNumericValue(value, allowNegative){
    value = String(value == null ? '' : value);
    var out = '';
    var seenDot = false;
    var seenMinus = false;
    for(var i=0;i<value.length;i++){
      var ch = value.charAt(i);
      if(ch >= '0' && ch <= '9'){
        out += ch;
      }else if(ch === '.' && !seenDot){
        out += ch;
        seenDot = true;
      }else if(ch === '-' && allowNegative && !seenMinus && out.length === 0){
        out += ch;
        seenMinus = true;
      }
    }
    return out;
  }
  function enforceNumeric(el){
    if(!isEditableNumericInput(el)) return;
    el.setAttribute('inputmode','decimal');
    el.setAttribute('autocomplete','off');
    var allowNegative = !(el.hasAttribute('min') && parseFloat(el.getAttribute('min')) >= 0);
    var clean = sanitizeNumericValue(el.value, allowNegative);
    if(el.value !== clean) el.value = clean;
    if(el.value !== '' && !Number.isFinite(Number(el.value))){
      el.classList.add('numericInvalid');
    }else{
      el.classList.remove('numericInvalid');
    }
  }
  function initNumericOnly(){
    document.querySelectorAll('input[type="number"]:not([disabled])').forEach(function(el){
      enforceNumeric(el);
      el.addEventListener('keydown', function(e){
        if(e.ctrlKey || e.metaKey || e.altKey) return;
        var allowed = ['Backspace','Delete','Tab','Escape','Enter','ArrowLeft','ArrowRight','ArrowUp','ArrowDown','Home','End'];
        if(allowed.indexOf(e.key) !== -1) return;
        if(e.key >= '0' && e.key <= '9') return;
        if(e.key === '.' && el.value.indexOf('.') === -1) return;
        var allowNegative = !(el.hasAttribute('min') && parseFloat(el.getAttribute('min')) >= 0);
        if(e.key === '-' && allowNegative && el.selectionStart === 0 && el.value.indexOf('-') === -1) return;
        e.preventDefault();
      });
      el.addEventListener('paste', function(e){
        e.preventDefault();
        var txt = (e.clipboardData || window.clipboardData).getData('text');
        var allowNegative = !(el.hasAttribute('min') && parseFloat(el.getAttribute('min')) >= 0);
        var insert = sanitizeNumericValue(txt, allowNegative);
        var start = el.selectionStart || 0;
        var end = el.selectionEnd || 0;
        var proposed = el.value.slice(0,start) + insert + el.value.slice(end);
        el.value = sanitizeNumericValue(proposed, allowNegative);
        el.dispatchEvent(new Event('input', {bubbles:true}));
        el.dispatchEvent(new Event('change', {bubbles:true}));
      });
      el.addEventListener('input', function(){ enforceNumeric(el); });
      el.addEventListener('change', function(){ enforceNumeric(el); });
    });
  }
  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', initNumericOnly);
  }else{
    initNumericOnly();
  }
})();
</script>
