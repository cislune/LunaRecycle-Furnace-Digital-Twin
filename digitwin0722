function saveFactSageRun(){
  const q = getFactSageQuery();
  if (!(q.regolithBasis > 0)) throw new Error("Regolith/process basis must be > 0 g before saving a run.");
  const run = {
    ...q,
    id: `fs_${Date.now()}_${Math.random().toString(36).slice(2, 9)}`,
    simulantKey: normalizeSimulantKey(q.simulantKey),
    mMetal_g: Number(fs_mMetal.value || 0),
    wCmetal_wt: Number(fs_wCmetal.value || 0),
    mSlag_g: Number(fs_mSlag.value || 0),
    nCO_mol: Number(fs_nCO.value || 0),
    nCO2_mol: Number(fs_nCO2.value || 0),
    mCleft_g: Number(fs_mCleft.value || 0),
    mCinput_g: Math.max(0, Number(getEffectiveCharMass() || 0))
      * Math.max(0, Math.min(1, Number(p2_fCchar ? p2_fCchar.value : 0.80)))
      * Math.max(0, Number(q.cMult || 1)),
    savedAt: Date.now()
  };
  if (!(run.mMetal_g >= 0)) throw new Error("Metal phase mass must be >= 0 g.");
  const runs = loadRuns();
  runs.push(run);
  saveRuns(runs);
  setActiveFactSageRun(run);
  refreshRunsUI();
  if (calibPill) calibPill.textContent = "Saved FactSage run active";
  if (fs_steelOut) fs_steelOut.textContent = `FactSage run saved and selected. Metal phase entered: ${run.mMetal_g.toFixed(6)} g. Click Calculate FactSage-Calibrated Steel Yield.`;
}

