    var feed=Math.max(0,num('lrc_py_feed'));
    var runLow=num('lrc_py_runLow'), runHigh=num('lrc_py_runHigh');
    var coolLow=num('lrc_py_coolLow'), coolHigh=num('lrc_py_coolHigh');
    var resetLow=num('lrc_py_resetLow'), resetHigh=num('lrc_py_resetHigh');
    var yChar=Math.max(0,num('lrc_py_yChar')), yCond=Math.max(0,num('lrc_py_yCond')), yGas=Math.max(0,num('lrc_py_yGas'));
    var ySum=yChar+yCond+yGas;
    if(ySum>0){ yChar/=ySum; yCond/=ySum; yGas/=ySum; }
    var char=feed*yChar, cond=feed*yCond, gas=feed*yGas;
    var betweenLow=coolLow+resetLow, betweenHigh=coolHigh+resetHigh;
    var cycleLow=runLow+betweenLow, cycleHigh=runHigh+betweenHigh;
