  };
}

function mantleHeatDuty(targetC, opts, reactionMassG, reactionHeatKJkg){
  const dT = Math.max(0, Number(targetC) - Number(opts.T0));
  const sensibleKJ = (Number(opts.Cfurn) + Number(opts.Cload)) * dT / 1000.0;
  const reactionKJ = Math.max(0, Number(reactionMassG || 0)) / 1000.0 * Math.max(0, Number(reactionHeatKJkg || 0));
  const usefulKJ = (sensibleKJ + reactionKJ) * Math.max(1, Number(opts.heatLossMult || 1));
  const electricalKJ = usefulKJ / Math.max(0.01, Number(opts.thermalEff || 0.65));
  const heatupSec = electricalKJ * 1000.0 / Math.max(1, Number(opts.furnacePowerW || 1200));
  return {dT, sensibleKJ, reactionKJ, usefulKJ, electricalKJ, electricalKWh:electricalKJ/3600.0, heatupSec};
}

function simulatePyrolysisWithThermal(opts, outage){
  const Rgas = 8.314462618;
  const dt = opts.dt || 1;
  const preliminary = mantleHeatDuty(opts.pyroTemp, opts, 0, 0);
  const rampSec = Math.max(dt, preliminary.heatupSec);
  const totalSec = rampSec + opts.pyroHoldSec;
  let alpha = 0, Tpeak = opts.T0, t500 = 0, t700 = 0;
  for (let t=0; t<totalSec; t+=dt){
    let Tc = t < rampSec ? opts.T0 + (opts.pyroTemp-opts.T0)*(t/rampSec) : opts.pyroTemp;
    if (outage && t >= outage.start && t <= outage.start + outage.duration){
      Tc = Math.max(opts.T0, Tc - Number(outage.coolRateCmin || 0) * ((t-outage.start)/60));
    }
    Tpeak = Math.max(Tpeak, Tc);
    if (Tc >= 500) t500 += dt;
    if (Tc >= 700) t700 += dt;
    const Tk = Tc + 273.15;
    const k = Math.max(0, Number(opts.A1||0)) * Math.exp(-Number(opts.Ea||0)/(Rgas*Tk));
    alpha = 1 - (1-alpha)*Math.exp(-k*dt);
    alpha = clamp(alpha,0,0.999999);
  }
  return {alpha, Tpeak, t500, t700, totalTime:totalSec, rampSec};
}

function runPyrolysisNominal(){
  try{
    const opts = getInputsForRun();
    if (!(opts.totalCharge > 0)) throw new Error("Dry vacuum process basis must be > 0 g after moisture/LOI removal.");
    const thermal = simulatePyrolysisWithThermal(opts, null);
    const alphaBase = clamp(thermal.alpha * opts.vpSeverity, 0, 0.999999);
    let organicRemaining = opts.organicDry;
    let lowVol=0, highVol=0, fracLiquid=0, fracGas=0;
    const volatilePool = opts.organicDry * (opts.yCond + opts.yGas);
    if (opts.seq === "fractionation_only" || opts.seq === "both"){
      lowVol = Math.min(organicRemaining, volatilePool * opts.vfLow);
      organicRemaining -= lowVol;
      highVol = Math.min(organicRemaining, volatilePool * opts.vfHigh);
      organicRemaining -= highVol;
      fracLiquid = lowVol*opts.vfLowLiq + highVol*opts.vfHighLiq;
      fracGas = lowVol*(1-opts.vfLowLiq) + highVol*(1-opts.vfHighLiq);
    }
    let pyChar=0, pyCond=0, pyGas=0, reacted=0;
    if (opts.seq === "pyrolysis_only" || opts.seq === "both"){
      reacted = organicRemaining * alphaBase;
      pyChar = reacted * opts.yChar + (organicRemaining - reacted);
      pyCond = reacted * opts.yCond;
      pyGas = reacted * opts.yGas;
    } else {
      pyChar = organicRemaining;
    }
    const recoveredSolidOrganic = (pyChar) * opts.solidRecovery;
    const solidTotal = recoveredSolidOrganic + opts.regolithMass;
    const pyroHeat = mantleHeatDuty(opts.pyroTemp, opts, reacted, opts.pyroDH);

    // Moisture removed from both the waste feedstock and the regolith LOI input
    // is recovered by the internal vacuum-fractionation/preconditioning step as
    // water condensate. This keeps the vacuum-stage mass balance on the actual
    // as-loaded process basis rather than silently discarding the moisture mass.
    const moistureWaterCondensate = Math.max(0, opts.totalWaterRemoved);
    const organicCondensableLiquid = fracLiquid + pyCond;
    const liquidTotal = moistureWaterCondensate + organicCondensableLiquid;
    const gasTotal = fracGas + pyGas;
    const vacuumProcessInputBasis = opts.totalDryBasis + moistureWaterCondensate;

    pyroState.ran = true;
    pyroState.feedstockName = opts.feedstockName;
    pyroState.mDry = opts.organicDry;
    pyroState.alpha = alphaBase;
    pyroState.mChar = recoveredSolidOrganic;
    pyroState.mCond = liquidTotal;
    pyroState.mGas = gasTotal;

    fracState.ran = true;
    fracState.use = true;
    fracState.treatmentMode = opts.seq;
    fracState.mSolidRecovered = recoveredSolidOrganic;
    fracState.mSolidsRaw = pyChar;
    fracState.mLiquid = liquidTotal;
    fracState.mGas = gasTotal;
    fracState.mLowMwC = lowVol + highVol;

    const modeLabel = opts.mode === "waste" ? "Waste feedstock only" : (opts.mode === "regolith" ? "Regolith simulant only" : "Waste feedstock + regolith mixture");
    const seqLabel = opts.seq === "fractionation_only" ? "Internal fractionation only" : (opts.seq === "pyrolysis_only" ? "Closed-vacuum pyrolysis" : "Internal fractionation preconditioning + closed-vacuum pyrolysis");
    output.textContent = `CLOSED-VACUUM PYROLYSIS â CALCULATED RESULTS

Key inputs for reference
  Feedstock:                              ${opts.feedstockName}
  As-loaded process mass [g]:             ${vacuumProcessInputBasis.toFixed(2)}
  Pyrolysis setpoint [C]:                  ${opts.pyroTemp.toFixed(2)}
  Pyrolysis hold time [min]:               ${(opts.pyroHoldSec/60).toFixed(2)}
  Mantle-furnace power [W]:                ${opts.furnacePowerW.toFixed(2)}
  Thermal efficiency [-]:                  ${opts.thermalEff.toFixed(2)}

Recovered product streams
  Organic solid / char [g]:             ${recoveredSolidOrganic.toFixed(6)}
  Organic condensable liquid [g]:        ${organicCondensableLiquid.toFixed(6)}
  Moisture-derived water [g]:            ${moistureWaterCondensate.toFixed(6)}
    From waste-feed moisture [g]:        ${opts.organicWaterRemoved.toFixed(6)}
    From regolith LOI/moisture [g]:      ${opts.regolithWaterRemoved.toFixed(6)}
  Total condensable liquid [g]:          ${liquidTotal.toFixed(6)}
  Gas / vapor [g]:                       ${gasTotal.toFixed(6)}
  Dry regolith / mineral residue [g]:    ${opts.regolithMass.toFixed(6)}
  Total recovered solids [g]:            ${solidTotal.toFixed(6)}

Mass-balance check
  As-loaded vacuum-process basis [g]:    ${vacuumProcessInputBasis.toFixed(6)}
  Dry product basis [g]:                 ${opts.totalDryBasis.toFixed(6)}
  Moisture routed to condensate [g]:     ${moistureWaterCondensate.toFixed(6)}
  Calculated output sum [g]:             ${(solidTotal + liquidTotal + gasTotal).toFixed(6)}
  Residual [g]:                          ${(vacuumProcessInputBasis - (solidTotal + liquidTotal + gasTotal)).toExponential(3)}

Mantle-furnace thermal result
  Pyrolysis setpoint [C]:                ${opts.pyroTemp.toFixed(2)}
  Estimated heat-up time [min]:          ${(pyroHeat.heatupSec/60).toFixed(2)}
  Hold time [min]:                       ${(opts.pyroHoldSec/60).toFixed(2)}
  Sensible heat [kJ]:                    ${pyroHeat.sensibleKJ.toFixed(3)}
  Effective reaction heat [kJ]:          ${pyroHeat.reactionKJ.toFixed(3)}
  Estimated electrical heat [kJ]:        ${pyroHeat.electricalKJ.toFixed(3)}
  Estimated electrical energy [kWh]:     ${pyroHeat.electricalKWh.toFixed(6)}
  Peak temperature [C]:                  ${thermal.Tpeak.toFixed(2)}
  Time at or above 500 C [s]:            ${thermal.t500.toFixed(0)}
  Time at or above 700 C [s]:            ${thermal.t700.toFixed(0)}`;

    if (frac_out) frac_out.textContent = `Calculated products: char ${recoveredSolidOrganic.toFixed(6)} g | condensate ${liquidTotal.toFixed(6)} g | gas ${gasTotal.toFixed(6)} g`;
    refreshCharToPart2();
    refreshPart3GatePreview();
  } catch(e){
    output.textContent = `ERROR: ${e.message}`;
    console.error(e);
  }
}

function calcMagneticMaterialFromOxides(){
  const mReg = Number(p2_regolithBasis.value);
  const loiPct = Number(p2_loiPct ? p2_loiPct.value : 0);
  const oxRaw = getOxideObj();
  const ox = applyFerricIronTreatment(oxRaw);
  const ironTreatment = getFerricIronTreatment();
  const oxSum = updateOxideSum();
  const oxBalanceNote = Number.isFinite(oxSum) && Math.abs(oxSum - 100.0) <= 0.005
    ? "balanced to 100.000 wt%"
    : "not exactly 100 wt%; check trace species, volatiles, blanks, or custom inputs";

  if (!(mReg > 0)) {
    reg_magOut.textContent = "ERROR: Regolith quantity must be > 0 g.";
    return;
  }
  if (!(loiPct >= 0 && loiPct <= 50)) {
    reg_magOut.textContent = "ERROR: LOI/moisture correction must be between 0 and 50 wt%.";
    return;
  }

  const mDry = mReg * (1 - loiPct / 100.0);

  // Estimated magnetic material. When Fe2O3-to-FeO-equivalent treatment is selected,
  // Fe2O3 is converted with the stoichiometric mass factor 2M(FeO)/M(Fe2O3) = 0.8998,
  // then set to zero so iron is never double-counted. TiO2 remains included as the
  // oxide-table proxy for the Ti-bearing portion of ilmenite-related material.
  const wFeO = Number(ox.FeO || 0);
  const wFe2O3 = Number(ox.Fe2O3 || 0);
  const wTiO2 = Number(ox.TiO2 || 0);
  const wMagProxy = wFeO + wFe2O3 + wTiO2;

  const mFeO = mDry * wFeO / 100.0;
  const mFe2O3 = mDry * wFe2O3 / 100.0;
  const mTiO2 = mDry * wTiO2 / 100.0;
  const mMagProxy = mFeO + mFe2O3 + mTiO2;

  const dryMagPct = mDry > 0 ? 100.0 * mMagProxy / mDry : NaN;
  const loadedMagPct = mReg > 0 ? 100.0 * mMagProxy / mReg : NaN;

  // Feed the result into the N52 beneficiation section.
  if (reg_magPhasePct) reg_magPhasePct.value = dryMagPct.toFixed(3);
  if (mb_feFeedPct) mb_feFeedPct.value = dryMagPct.toFixed(3);
  if (mb_regolithMass) mb_regolithMass.value = mDry.toFixed(3);

  reg_magOut.textContent =
`================ PART 1 MAGNETIC MATERIAL ESTIMATE ================
Key inputs for reference
  Loaded regolith [g]:                       ${mReg.toFixed(3)}
  LOI / moisture [wt%]:                      ${loiPct.toFixed(2)}

Dry regolith basis [g]:                      ${mDry.toFixed(3)}
Oxide wt% sum [-]:                            ${Number.isFinite(oxSum) ? oxSum.toFixed(3) : "N/A"} (${oxBalanceNote})
Ferric iron treatment:                       ${ironTreatment === "feo_equiv" ? "FeâOâ converted to FeO-equivalent" : "FeO and FeâOâ retained separately"}

Estimated magnetically relevant oxide fraction
  Estimated fraction [% dry basis]:          ${dryMagPct.toFixed(3)}
  FeO contribution [g]:                      ${mFeO.toFixed(3)}
  FeâOâ contribution [g]:                    ${mFe2O3.toFixed(3)}
  TiOâ contribution [g]:                     ${mTiO2.toFixed(3)}
  Total estimated magnetic material [g]:     ${mMagProxy.toFixed(3)}

Actual captured concentrate is calculated in Part 2 using the N52 magnetic separation model.
===================================================================`;
}


/* === FACTSAGE / PART 3 SUPPORT FUNCTIONS === */
function downloadText(filename, text){
  const blob = new Blob([text || ""], { type: "text/plain;charset=utf-8" });
  const url = URL.createObjectURL(blob);
  const a = document.createElement("a");
  a.href = url;
  a.download = filename;
  document.body.appendChild(a);
  a.click();
  a.remove();
  URL.revokeObjectURL(url);
}

function getFactSageQuery(){
  const key = simulantPreset ? simulantPreset.value : "custom";
  const opt = simulantPreset ? simulantPreset.options[simulantPreset.selectedIndex] : null;
  const ox = getEffectiveOxideObjForProcess();
  return {
    simulantKey: normalizeSimulantKey(key),
    simulantName: opt ? opt.textContent : "Custom / measured oxide table",
    Tc: Number(p2_Tc ? p2_Tc.value : 1550),
    Pbar: Number(p2_Pbar ? p2_Pbar.value : 1.0),
    regolithBasis: Number(getEffectiveRegolithBasis()),
    cMult: Number(p2_cMult ? p2_cMult.value : 1.0),
    oxHash: hashOx(ox),
    ox
  };
}

function refreshRunsUI(){
  const runs = loadRuns();
  if (runCountPill) runCountPill.textContent = `${runs.length} run${runs.length === 1 ? "" : "s"}`;
  if (calibPill) {
    const active = getActiveFactSageRun(runs);
    calibPill.textContent = active ? "Saved FactSage run active" : (runs.length ? "FactSage data loaded" : "No FactSage data loaded");
  }
  if (fs_runsList) renderRunsList(runs, fs_runsList);
  refreshPart3GatePreview();
}

function buildRecipe(){
  try{
    const q = getFactSageQuery();
    const charMass = Number(getEffectiveCharMass());
    if (!(q.regolithBasis > 0)) throw new Error("Regolith/process basis must be > 0 g.");
    if (!(charMass >= 0)) throw new Error("Run Part 3: Pyrolysis first so a char/carbon source exists.");
    const oxSum = Object.values(q.ox).reduce((a,b)=>a + Number(b || 0), 0);
    fs_output.value = buildRecipeText({
      simulantName: q.simulantName,
      basisReg: q.regolithBasis,
      charMass,
      fC: Number(p2_fCchar ? p2_fCchar.value : 0.80),
      cMult: q.cMult,
      Tc: q.Tc,
      Pbar: q.Pbar,
      atmosphere: atmosphereInput ? atmosphereInput.value : "Ar",
      vacuumPa: vacuumPaInput ? vacuumPaInput.value : 100,
      ox: q.ox,
      oxSum
    });
  } catch(e){
    fs_output.value = `ERROR: ${e.message}`;
  }
