const FE2O3_TO_FEO_EQUIVALENT = (2 * 71.844) / 159.687; // 0.8998; preserves elemental Fe mass

function getFerricIronTreatment(){
  return p2_feTreatment ? p2_feTreatment.value : "as_entered";
}

function applyFerricIronTreatment(oxideObj){
  const treated = { ...oxideObj };
  if (getFerricIronTreatment() === "feo_equiv") {
    const originalFeO = Number(treated.FeO || 0);
    const originalFe2O3 = Number(treated.Fe2O3 || 0);
    treated.FeO = originalFeO + FE2O3_TO_FEO_EQUIVALENT * originalFe2O3;
    treated.Fe2O3 = 0;
  }
  return treated;
}

function getEffectiveOxideObjForProcess(){
  const base = applyFerricIronTreatment(getOxideObj());
  const stream = getSelectedBeneficiationStream();
  if (!stream) return base;

  const magneticKeys = ["FeO", "Fe2O3", "TiO2"];
  const magneticSum = magneticKeys.reduce((a,k)=>a + Number(base[k] || 0), 0);
  const gangueKeys = Object.keys(base).filter(k => !magneticKeys.includes(k));
  const gangueSum = gangueKeys.reduce((a,k)=>a + Number(base[k] || 0), 0);

  const mStream = Number(stream.mass);
  const mMag = Math.max(0, Number(stream.magneticMass || 0));
  const mGangue = Math.max(0, Number(stream.gangueMass || 0));
  if (!(mStream > 0)) return base;

  const out = {};
  for (const k of magneticKeys){
    const share = magneticSum > 0 ? Number(base[k] || 0) / magneticSum : 0;
    out[k] = 100.0 * (mMag * share) / mStream;
  }
  for (const k of gangueKeys){
    const share = gangueSum > 0 ? Number(base[k] || 0) / gangueSum : 0;
    out[k] = 100.0 * (mGangue * share) / mStream;
  }
  return out;
}

