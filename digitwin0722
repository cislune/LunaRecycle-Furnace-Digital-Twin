    var inert=clamp(num('lrc_sci_inert')/100,0,0.95);
    if(moist+inert>0.98){ inert=0.98-moist; }
    var dry=feed*Math.max(0,1-moist-inert);
    var inertMass=feed*inert;
    var waterMass=feed*moist;
    var A=Number((byId('lrc_sci_A')||{}).value);
    if(!Number.isFinite(A) || A<0) A=0;
    var Ea=Math.max(0,num('lrc_sci_Ea'));
    var order=clamp(num('lrc_sci_order'),0.1,5);
    var T0=num('lrc_sci_T0'), Tset=num('lrc_sci_Tset');
    var ramp=Math.max(0.001,num('lrc_sci_ramp'));
    var holdMin=Math.max(0,num('lrc_sci_hold'));
    var dt=clamp(num('lrc_sci_dt'),0.1,60);
    var pPa=Math.max(0.001,num('lrc_sci_pressure'));
    var pressureSeverity=clamp(1 + 0.06*Math.log10(101325/pPa), 0.85, 1.35);
    var rampSec=Math.abs(Tset-T0)/ramp*60;
    var holdSec=holdMin*60;
    var totalSec=rampSec+holdSec;
    var alpha=0;
    var t500=0,t700=0,peak=-1e9,integral=0;
    for(var t=0; t<=totalSec; t+=dt){
      var Tc;
      if(t<=rampSec){ Tc = T0 + (Tset-T0)*(t/Math.max(rampSec,1e-9)); }
      else { Tc = Tset; }
      peak=Math.max(peak,Tc);
      if(Tc>=500) t500 += dt;
      if(Tc>=700) t700 += dt;
      var Tk=Tc+273.15;
      var k=A*Math.exp(-Ea/(R*Tk))*pressureSeverity;
      if(!Number.isFinite(k) || k<0) k=0;
      integral += k*dt;
      var rate=k*Math.pow(Math.max(0,1-alpha),order);
      alpha += rate*dt;
      if(alpha>=0.999999){ alpha=0.999999; break; }
      if(alpha<0) alpha=0;
    }
    alpha=clamp(alpha,0,1);
    var yChar=clamp(num('lrc_sci_yChar'),0,1), yCond=clamp(num('lrc_sci_yCond'),0,1), yGas=clamp(num('lrc_sci_yGas'),0,1);
