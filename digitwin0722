<script id="definitive-feedstock-yield-sync">
(function(){
  "use strict";

  const FIXED_FEEDSTOCK_YIELDS = Object.freeze({
    cellulose: Object.freeze({ name: "Cotton T-shirt", char: 0.1800, condensable: 0.6000, gas: 0.2200 }),
    nitrile: Object.freeze({ name: "Nitrile Gloves", char: 0.4291, condensable: 0.3900, gas: 0.1809 }),
    polyolefin: Object.freeze({ name: "Polyethylene Bag", char: 0.0300, condensable: 0.7400, gas: 0.2300 }),
    laminate: Object.freeze({ name: "Foil Coffee Pouch", char: 0.1200, condensable: 0.6300, gas: 0.2500 })
  });

  function setValue(id, value, digits){
    const el = document.getElementById(id);
    if (!el) return;
    el.value = Number(value).toFixed(digits);
    el.setAttribute("value", el.value);
  }

  function applyFixedFeedstockYields(){
    const selector = document.getElementById("materialPreset");
    if (!selector) return;
    const preset = FIXED_FEEDSTOCK_YIELDS[selector.value];
    if (!preset) {
      // Blend and Custom are intentionally editable. This explicit unlock is
      // required when switching away from an individual fixed-yield preset.
      const editableInputs = [
        document.getElementById("yChar"),
        document.getElementById("yCond"),
        document.getElementById("yGas")
      ].filter(Boolean);
      editableInputs.forEach(function(el){
        el.readOnly = false;
        el.setAttribute("aria-readonly", "false");
        el.classList.remove("autoCalculated");
      });
      return;
    }

    setValue("yChar", preset.char, 4);
    setValue("yCond", preset.condensable, 4);
    setValue("yGas", preset.gas, 4);

    // Keep the separate pyrolysis-cycle calculator synchronized too.
    setValue("lrc_py_yChar", preset.char, 4);
    setValue("lrc_py_yCond", preset.condensable, 4);
    setValue("lrc_py_yGas", preset.gas, 4);

    const charInput = document.getElementById("yChar");
    const condInput = document.getElementById("yCond");
    const gasInput = document.getElementById("yGas");
    [charInput, condInput, gasInput].filter(Boolean).forEach(function(el){
      el.readOnly = true;
      el.setAttribute("aria-readonly", "true");
      el.classList.add("autoCalculated");
    });

    const charNote = document.getElementById("yCharRangeNote");
    const condNote = document.getElementById("yCondRangeNote");
    const gasNote = document.getElementById("yGasRangeNote");
    if (charNote) charNote.textContent = preset.name + " fixed char / solid yield: " + (preset.char * 100).toFixed(2) + " wt% of dry reactive feed.";
    if (condNote) condNote.textContent = preset.name + " fixed condensable yield: " + (preset.condensable * 100).toFixed(2) + " wt% of dry reactive feed.";
    if (gasNote) gasNote.textContent = preset.name + " fixed gas yield: " + (preset.gas * 100).toFixed(2) + " wt% of dry reactive feed.";

    const sum = preset.char + preset.condensable + preset.gas;
    const sumInput = document.getElementById("yieldSum");
    if (sumInput) sumInput.value = sum.toFixed(6) + " (" + (sum * 100).toFixed(3) + "%)";

    const lockNote = document.getElementById("yieldLockNote");
    if (lockNote) {
      lockNote.textContent = preset.name + ": fixed preset yields loaded automatically â " +
        (preset.char * 100).toFixed(2) + " wt% char/solid, " +
        (preset.condensable * 100).toFixed(2) + " wt% condensables, and " +
        (preset.gas * 100).toFixed(2) + " wt% gas.";
    }

    // Notify dependent calculators that the values changed.
    [charInput, condInput, gasInput].filter(Boolean).forEach(function(el){
      el.dispatchEvent(new Event("input", { bubbles: true }));
    });
  }

  function enforceAfterOtherHandlers(){
    applyFixedFeedstockYields();
    setTimeout(applyFixedFeedstockYields, 0);
    setTimeout(applyFixedFeedstockYields, 50);
  }

  function initialize(){
    const selector = document.getElementById("materialPreset");
    if (!selector) return;
    selector.addEventListener("change", enforceAfterOtherHandlers);
    selector.addEventListener("input", enforceAfterOtherHandlers);
    enforceAfterOtherHandlers();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initialize, { once: true });
  } else {
    initialize();
  }
})();
</script>


<script>
/* Standalone FactSage runtime fallback.
   This block does not depend on the large legacy initialization IIFE. */
(function () {
  'use strict';
  var RUNS_KEY = 'digitwinpyro_factsage_runs_v1';
  var ACTIVE_KEY = 'digitwinpyro_factsage_active_run_v1';
  var memoryRuns = [];
  var memoryActive = null;

  function el(id) { return document.getElementById(id); }
  function num(id, fallback) {
    var node = el(id);
    var value = node ? Number(node.value) : Number(fallback || 0);
    return Number.isFinite(value) ? value : Number(fallback || 0);
  }
  function text(id, value) { var node = el(id); if (node) node.textContent = value; }
  function normalizeSimulant(value) {
    var k = String(value || '').toLowerCase().replace(/[^a-z0-9]/g, '');
    if (k === 'jsc1' || k === 'jsc1a') return 'jsc1a';
    if (k === 'lhs1') return 'lhs1';
    if (k === 'nulht' || k === 'nulht2m') return 'nulht2m';
    return k || 'custom';
  }
  function loadRuns() {
    try {
      var raw = localStorage.getItem(RUNS_KEY);
      var parsed = raw ? JSON.parse(raw) : [];
      if (Array.isArray(parsed)) memoryRuns = parsed;
      memoryActive = localStorage.getItem(ACTIVE_KEY) || memoryActive;
    } catch (_) {}
    return Array.isArray(memoryRuns) ? memoryRuns : [];
  }
  function storeRuns(runs) {
    memoryRuns = Array.isArray(runs) ? runs : [];
    try { localStorage.setItem(RUNS_KEY, JSON.stringify(memoryRuns)); } catch (_) {}
  }
  function setActive(id) {
    memoryActive = id || null;
    try {
      if (memoryActive) localStorage.setItem(ACTIVE_KEY, memoryActive);
      else localStorage.removeItem(ACTIVE_KEY);
    } catch (_) {}
  }
  function currentFeedstockState() {
    var selector = el('materialPreset');
    var feedstockKey = selector ? String(selector.value || '') : '';
    var feedstockName = selector && selector.options[selector.selectedIndex]
      ? selector.options[selector.selectedIndex].textContent.trim()
      : (feedstockKey || 'Unknown feedstock');

    var charNode = el('p2_charMass');
    var charMass = charNode ? Number(charNode.value) : NaN;
    var fixedCarbonRaw = num('p2_fCchar', 0.80);
    var fixedCarbonFraction = fixedCarbonRaw > 1 ? fixedCarbonRaw / 100 : fixedCarbonRaw;
    fixedCarbonFraction = Math.max(0, Math.min(1, fixedCarbonFraction));
    var carbonMultiplier = Math.max(0, num('p2_cMult', 1));
    var charYield = Math.max(0, num('yChar', 0));
    var condensableYield = Math.max(0, num('yCond', 0));
    var gasYield = Math.max(0, num('yGas', 0));

    return {
      feedstockKey: feedstockKey,
      feedstockName: feedstockName,
      charMass: Number.isFinite(charMass) ? Math.max(0, charMass) : NaN,
      fixedCarbonFraction: fixedCarbonFraction,
      carbonMultiplier: carbonMultiplier,
      carbonAvailable: Number.isFinite(charMass)
        ? Math.max(0, charMass) * fixedCarbonFraction * carbonMultiplier
        : NaN,
      charYield: charYield,
      condensableYield: condensableYield,
      gasYield: gasYield
    };
  }

  function currentQuery() {
    var preset = el('simulantPreset');
    var key = preset ? preset.value : 'custom';
    var name = preset && preset.options[preset.selectedIndex] ? preset.options[preset.selectedIndex].textContent : key;
    var ox = {};
    ['SiO2','Al2O3','FeO','Fe2O3','CaO','MgO','TiO2','Na2O','K2O','MnO','P2O5','Cr2O3'].forEach(function (k) {
      ox[k] = Math.max(0, num('ox_' + k, 0));
    });
    return {
      simulantKey: normalizeSimulant(key),
      simulantName: name,
      Tc: num('p2_Tc', num('mfCtrTemp', 1600)),
      Pbar: num('p2_Pbar', 1),
      regolithBasis: Math.max(0, num('p2_regolithBasis', num('pyro_regolithChargeMass', 0))),
      cMult: Math.max(0, num('p2_cMult', 1)),
      ox: ox
    };
  }
  function chooseRun(runs, q) {
    if (!runs.length) return null;

    /* Never reuse an active run from a different simulant. */
    var active = runs.find(function (r) {
      return String(r.id || '') === String(memoryActive || '') &&
        normalizeSimulant(r.simulantKey) === q.simulantKey;
    });
    if (active) return active;

    /* Only runs for the currently selected simulant are eligible. */
    var same = runs.filter(function (r) {
      return normalizeSimulant(r.simulantKey) === q.simulantKey;
    });
    if (!same.length) return null;

    same.sort(function (a, b) {
      var da = Math.abs(Number(a.Tc || 0) - q.Tc) +
        100 * Math.abs(Number(a.Pbar || 0) - q.Pbar) +
        Math.abs(Number(a.cMult || 1) - q.cMult);
      var db = Math.abs(Number(b.Tc || 0) - q.Tc) +
        100 * Math.abs(Number(b.Pbar || 0) - q.Pbar) +
        Math.abs(Number(b.cMult || 1) - q.cMult);
      return da - db;
    });
    return same[0] || null;
  }
  function renderRuns() {
    var runs = loadRuns();
    text('runCountPill', runs.length + ' run' + (runs.length === 1 ? '' : 's'));
    text('calibPill', runs.length ? 'Saved FactSage run active' : 'No FactSage data loaded');
    var list = el('fs_runsList');
    if (list) {
      list.textContent = runs.length ? runs.map(function (r, i) {
        return (i + 1) + '. ' + (r.simulantName || r.simulantKey || 'Run') +
          ' | basis ' + Number(r.regolithBasis || 0).toFixed(3) + ' g' +
          ' | metal ' + Number(r.mMetal_g || 0).toFixed(6) + ' g' +
          (String(r.id || '') === String(memoryActive || '') ? ' | ACTIVE' : '');
      }).join('\n') : 'No saved runs yet.';
    }
  }

  function saveFactSageRunStandalone() {
    var q = currentQuery();
    var feed = currentFeedstockState();
    if (!(q.regolithBasis > 0)) throw new Error('Regolith/process basis must be greater than zero before saving a run.');
    var run = {
      id: 'fs_' + Date.now() + '_' + Math.random().toString(36).slice(2, 9),
      simulantKey: q.simulantKey,
      simulantName: q.simulantName,
      Tc: q.Tc,
      Pbar: q.Pbar,
      regolithBasis: q.regolithBasis,
      cMult: q.cMult,
      ox: q.ox,
      mMetal_g: Math.max(0, num('fs_mMetal', 0)),
      wCmetal_wt: Math.max(0, num('fs_wCmetal', 0)),
      mSlag_g: Math.max(0, num('fs_mSlag', 0)),
      nCO_mol: Math.max(0, num('fs_nCO', 0)),
      nCO2_mol: Math.max(0, num('fs_nCO2', 0)),
      mCleft_g: Math.max(0, num('fs_mCleft', 0)),
      mCinput_g: Number.isFinite(feed.carbonAvailable) ? feed.carbonAvailable : null,
      feedstockKey: feed.feedstockKey,
      feedstockName: feed.feedstockName,
      charMass_g: Number.isFinite(feed.charMass) ? feed.charMass : null,
      charYield: feed.charYield,
      condensableYield: feed.condensableYield,
      gasYield: feed.gasYield,
      savedAt: Date.now()
    };
    var runs = loadRuns();
    runs.push(run);
    storeRuns(runs);
    setActive(run.id);
    renderRuns();
    text('fs_steelOut', 'FactSage run saved and selected. Metal phase entered: ' + run.mMetal_g.toFixed(6) + ' g. Click Calculate FactSage-Calibrated Steel Yield.');
    return run;
  }

  function calcSteelStandalone() {
    var q = currentQuery();
    var feed = currentFeedstockState();
    var runs = loadRuns();
    var run = chooseRun(runs, q);
    if (!run) {
      text('fs_steelOut', 'ERROR: No saved FactSage run matches the currently selected simulant (' + q.simulantName + '). Save a FactSage run for this simulant before calculating metal yield.');
      return;
    }
    var runBasis = Number(run.regolithBasis || 0);
    if (!(runBasis > 0) || !(q.regolithBasis > 0)) {
      text('fs_steelOut', 'ERROR: Current and saved FactSage regolith bases must both be greater than zero.');
      return;
    }
    if (!Number.isFinite(feed.charMass)) {
      text('fs_steelOut', 'ERROR: Run Closed-Vacuum Pyrolysis again after selecting the current feedstock so the current char mass is available for the metal-yield calculation.');
      return;
    }

    var basisScale = q.regolithBasis / runBasis;
    var savedCarbonInput = Number(run.mCinput_g);
    var currentCarbonInput = Number(feed.carbonAvailable);
    var carbonScale = 1;

    if (Number.isFinite(savedCarbonInput) && savedCarbonInput > 0 && Number.isFinite(currentCarbonInput)) {
      carbonScale = Math.max(0, Math.min(1, currentCarbonInput / savedCarbonInput));
    }

    var productScale = basisScale * carbonScale;
    var metal = Math.max(0, Number(run.mMetal_g || 0)) * productScale;
    var slag = Math.max(0, Number(run.mSlag_g || 0)) * basisScale;
    var co = Math.max(0, Number(run.nCO_mol || 0)) * productScale;
    var co2 = Math.max(0, Number(run.nCO2_mol || 0)) * productScale;
    var cLeft = Math.max(0, Number(run.mCleft_g || 0)) * productScale;
    var yieldPct = q.regolithBasis > 0 ? 100 * metal / q.regolithBasis : 0;
    var result = [
      '================ FACTSAGE METAL-YIELD RESULT ================',
      'Current selected simulant: ' + q.simulantName,
      'Saved run used: ' + (run.simulantName || run.simulantKey || 'FactSage run'),
      'Saved run basis [g]: ' + runBasis.toFixed(3),
      'Current dry-regolith basis [g]: ' + q.regolithBasis.toFixed(3),
      'Regolith-basis scale factor: ' + basisScale.toFixed(6),
      'Current feedstock: ' + feed.feedstockName,
      'Current fixed char yield [-]: ' + feed.charYield.toFixed(6),
      'Current char mass after latest pyrolysis run [g]: ' + feed.charMass.toFixed(6),
      'Current fixed-carbon fraction [-]: ' + feed.fixedCarbonFraction.toFixed(6),
      'Current carbon available to CTR [g]: ' + currentCarbonInput.toFixed(6),
      'Saved-run feedstock: ' + (run.feedstockName || 'not stored in legacy run'),
      'Saved-run carbon input [g]: ' + (Number.isFinite(savedCarbonInput) ? savedCarbonInput.toFixed(6) : 'not stored'),
      'Carbon-limiting factor: ' + carbonScale.toFixed(6),
      'Combined product scale factor: ' + productScale.toFixed(6),
      'CTR temperature [C]: ' + q.Tc.toFixed(2),
      'Pressure [bar]: ' + q.Pbar.toFixed(4),
      '',
      'Scaled metal product [g]: ' + metal.toFixed(6),
      'Metal yield [wt% dry regolith]: ' + yieldPct.toFixed(4),
      'Scaled slag [g]: ' + slag.toFixed(6),
      'Scaled CO [mol]: ' + co.toFixed(6),
      'Scaled CO2 [mol]: ' + co2.toFixed(6),
      'Scaled unreacted carbon [g]: ' + cLeft.toFixed(6),
      'Metal carbon [wt% C]: ' + Math.max(0, Number(run.wCmetal_wt || 0)).toFixed(4),
      '',
      metal > 0 ? 'Basis: saved FactSage metal phase scaled to the current regolith basis and limited by the current feedstock-derived carbon availability.' : 'WARNING: The selected saved FactSage run contains 0 g metal or the current feedstock supplies no available carbon, so the calculated metal yield is 0.',
      '============================================================='
    ].join('\n');
    text('fs_steelOut', result);
  }

  function copySteelStandalone() {
    var out = el('fs_steelOut');
    if (!out) return;
    if (navigator.clipboard && navigator.clipboard.writeText) navigator.clipboard.writeText(out.textContent || '').catch(function () {});
  }

  /* Always install these functions. This guarantees the final binder has a
     working implementation even when the legacy script stops early. */
  window.saveFactSageRun = saveFactSageRunStandalone;
  window.calcSteelFromFactSage = calcSteelStandalone;
  window.refreshRunsUI = renderRuns;
  window.copySteel = copySteelStandalone;

  function syncActiveRunToCurrentSimulant() {
    var q = currentQuery();
    var runs = loadRuns();
    var matching = runs.filter(function (r) {
      return normalizeSimulant(r.simulantKey) === q.simulantKey;
    });

    if (!matching.length) {
      setActive(null);
      renderRuns();
      text('fs_steelOut', 'Selected simulant changed to ' + q.simulantName + '. No matching saved FactSage run is active; save a run for this simulant before calculating metal yield.');
      return;
    }

    matching.sort(function (a, b) { return Number(b.savedAt || 0) - Number(a.savedAt || 0); });
    setActive(matching[0].id);
    renderRuns();
    text('fs_steelOut', 'Selected simulant changed to ' + q.simulantName + '. Matching saved FactSage run selected: ' + (matching[0].simulantName || matching[0].simulantKey) + '.');
  }

  function init() {
    renderRuns();
    var preset = el('simulantPreset');
    if (preset) preset.addEventListener('change', syncActiveRunToCurrentSimulant);
    var feedstockPreset = el('materialPreset');
    if (feedstockPreset) feedstockPreset.addEventListener('change', function () {
      var feed = currentFeedstockState();
      text('fs_steelOut', 'Feedstock changed to ' + feed.feedstockName + '. Run Closed-Vacuum Pyrolysis again, then calculate metal yield to use the new char and carbon availability.');
    });
    var clear = el('fs_clearRunsBtn');
    if (clear) clear.addEventListener('click', function (event) {
      event.preventDefault();
      storeRuns([]); setActive(null); renderRuns(); text('fs_steelOut', 'All saved FactSage runs were deleted.');
    });
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init, { once: true });
  else init();
})();
</script>

<script>
/* Final isolated FactSage control binding.
   This runs after all legacy scripts so earlier initialization failures cannot
   leave the Save or Calculate buttons without working click handlers. */
(function () {
  function showMetalMessage(message) {
    var out = document.getElementById('fs_steelOut');
    if (out) out.textContent = message;
  }

  function replaceAndBind(id, handler) {
    var oldButton = document.getElementById(id);
    if (!oldButton) return;
    var newButton = oldButton.cloneNode(true);
    newButton.type = 'button';
    oldButton.parentNode.replaceChild(newButton, oldButton);
    newButton.addEventListener('click', function (event) {
      event.preventDefault();
      event.stopPropagation();
      try {
        handler();
      } catch (error) {
        console.error(error);
        showMetalMessage('ERROR: ' + (error && error.message ? error.message : String(error)));
      }
    });
  }

  function bindFactSageControls() {
    replaceAndBind('fs_saveRunBtn', function () {
      if (typeof window.saveFactSageRun !== 'function') {
        throw new Error('FactSage save logic did not initialize. Reload this corrected file.');
      }
      window.saveFactSageRun();
      if (typeof window.refreshRunsUI === 'function') window.refreshRunsUI();
    });

    replaceAndBind('fs_calcSteelBtn', function () {
      if (typeof window.calcSteelFromFactSage !== 'function') {
        throw new Error('Metal-yield calculation logic did not initialize. Reload this corrected file.');
      }
      showMetalMessage('Calculating metal yield...');
      window.calcSteelFromFactSage();
    });

    replaceAndBind('fs_copySteelBtn', function () {
      if (typeof window.copySteel === 'function') window.copySteel();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bindFactSageControls, { once: true });
  } else {
    bindFactSageControls();
  }
})();
</script>


<script id="thermocompression-full-process-model">
(function(){
  'use strict';
  function el(id){ return document.getElementById(id); }
  function n(id){ var x=el(id), z=x?Number(x.value):0; return Number.isFinite(z)?z:0; }
  function f(x,d){ return Number.isFinite(x)?x.toFixed(d==null?2:d):'--'; }
  function pct(x,total){ return total>0?100*x/total:0; }
  function clamp(x,a,b){ return Math.max(a,Math.min(b,x)); }

  function run(){
    var nomex=Math.max(0,n('tc_nomex_g'));
    var pe=Math.max(0,n('tc_pe_g'));
    var coffee=Math.max(0,n('tc_coffee_g'));
    var charge=nomex+pe+coffee;

    var dieLengthIn=Math.max(0.1,n('tc_die_length_in'));
    var dieWidthIn=Math.max(0.1,n('tc_die_width_in'));
    var dieDepthIn=Math.max(0.01,n('tc_die_depth_in'));

    var initial=n('tc_initial_c');
    var target=n('tc_target_c');
    var pressure=Math.max(0,n('tc_pressure_mpa'));
    var tTarget=Math.max(0,n('tc_target_time_min'));
    var tSoakStart=Math.max(0,n('tc_soak_start_min'));
    var tSoakEnd=Math.max(0,n('tc_soak_end_min'));
    var tFullP=Math.max(0,n('tc_full_pressure_min'));
    var tOff=Math.max(0,n('tc_heat_off_min'));
    var tEnd=Math.max(0,n('tc_end_min'));
    var energy=Math.max(0,n('tc_energy_kwh'));

    var soakDuration=Math.max(0,tSoakEnd-tSoakStart);
    var fullPressureDuration=Math.max(0,tOff-tFullP);
    var coolDuration=Math.max(0,tEnd-tOff);
    var totalDuration=tEnd;
    var avgRamp=tTarget>0?(target-initial)/tTarget:0;
    var avgPower=totalDuration>0?energy/(totalDuration/60):0;
    var energyPerKg=charge>0?energy/(charge/1000):0;

    /* Reduced-order consolidation model calibrated to the documented
       competition run: 280 g total charge, 200 C target, 5 MPa final pressure,
       30 min soak, staged loading, and a 0.75 in-deep square aluminum die.
       The report does not state the cavity side length, so the measurable
       length and width remain user inputs; 8 x 8 in is the baseline geometry. */
    var meltActivation=clamp((target-120)/80,0,1.25);
    var soakActivation=1-Math.exp(-soakDuration/20);
    var pressureActivation=1-Math.exp(-pressure/2.5);
    var baselineActivation=(1-Math.exp(-30/20))*(1-Math.exp(-5/2.5));
    var consolidationIndex=baselineActivation>0
      ? clamp(meltActivation*soakActivation*pressureActivation/baselineActivation,0,1.5)
      : 0;

    var peFrac=charge>0?pe/charge:0;
    var nomexFrac=charge>0?nomex/charge:0;
    var coffeeFrac=charge>0?coffee/charge:0;
    var meltableFrac=clamp(peFrac+0.55*coffeeFrac,0,1);

    /* Flash fraction rises with molten-polymer availability, temperature,
       pressure, full-pressure time, and cavity overfill. */
    var rhoNomex=1.38, rhoPE=0.94, rhoCoffee=1.18; // g/cm3 effective material densities
    var solidSpecificVolume=charge>0
      ? (nomex/rhoNomex + pe/rhoPE + coffee/rhoCoffee)/charge
      : 0;
    var solidDensity=solidSpecificVolume>0?1/solidSpecificVolume:1.0;

    var obstruction=clamp(1.10*nomexFrac+0.80*coffeeFrac,0,1);
    var infiltrationIndex=clamp(consolidationIndex*(1-0.85*obstruction),0,1.5);
    var residualVoidFrac=clamp(0.025 + 0.16*Math.max(0,0.90-infiltrationIndex)
      +0.05*Math.max(0,0.80-consolidationIndex),0.015,0.24);
    var compositeDensity=solidDensity*(1-residualVoidFrac);

    var IN_TO_CM=2.54;
    var dieLengthCm=dieLengthIn*IN_TO_CM;
    var dieWidthCm=dieWidthIn*IN_TO_CM;
    var dieDepthCm=dieDepthIn*IN_TO_CM;
    var dieAreaCm2=dieLengthCm*dieWidthCm;
    var dieCapacityCm3=dieAreaCm2*dieDepthCm;
    var unconstrainedChargeVolume=charge>0?charge/Math.max(0.1,compositeDensity):0;
    var fillRatio=dieCapacityCm3>0?unconstrainedChargeVolume/dieCapacityCm3:0;

    var pressureTerm=clamp(pressure/5,0,2);
    var temperatureTerm=clamp((target-110)/90,0,1.6);
    var pressureTimeTerm=clamp(fullPressureDuration/1,0,3);
    var overfillTerm=clamp(0.85+0.70*Math.max(0,fillRatio-0.55),0.75,1.50);
    var baselineMeltable=(150/280)+0.55*(65/280);
    var flashFrac=clamp(0.045*(baselineMeltable>0?meltableFrac/baselineMeltable:1)
      *pressureTerm*temperatureTerm*(0.85+0.15*pressureTimeTerm)*overfillTerm,0,0.20);

    var lossFrac=clamp(0.0005+0.003*Math.max(0,0.75-consolidationIndex)
      +0.001*Math.max(0,(target-220)/40),0,0.03);
    var processLoss=charge*lossFrac;
    var recoveredBeforeTrim=Math.max(0,charge-processLoss);
    var flashMass=Math.min(recoveredBeforeTrim,recoveredBeforeTrim*flashFrac);
    var finalComposite=Math.max(0,recoveredBeforeTrim-flashMass);

    /* Final part dimensions. The trimmed part follows the cavity footprint.
       Thickness is mass / (effective density x cavity area), capped by cavity
       depth. Flash is treated as a thinner perimeter sheet around the cavity. */
    var trimmedVolumeCm3=compositeDensity>0?finalComposite/compositeDensity:0;
    var trimmedThicknessCm=dieAreaCm2>0?trimmedVolumeCm3/dieAreaCm2:0;
    trimmedThicknessCm=Math.min(trimmedThicknessCm,dieDepthCm);
    var trimmedThicknessIn=trimmedThicknessCm/IN_TO_CM;

    var flashDensity=Math.max(0.85,solidDensity*0.96);
    var flashVolumeCm3=flashDensity>0?flashMass/flashDensity:0;
    var flashThicknessCm=Math.max(0.08,trimmedThicknessCm*0.55);
    var flashAreaCm2=flashThicknessCm>0?flashVolumeCm3/flashThicknessCm:0;
    var outerAreaCm2=dieAreaCm2+flashAreaCm2;
    var aspect=dieWidthCm>0?dieLengthCm/dieWidthCm:1;
    var outerWidthCm=Math.sqrt(Math.max(0,outerAreaCm2/Math.max(0.01,aspect)));
    var outerLengthCm=aspect*outerWidthCm;
    var withFlashLengthIn=outerLengthCm/IN_TO_CM;
    var withFlashWidthIn=outerWidthCm/IN_TO_CM;
    var withFlashThicknessIn=Math.max(trimmedThicknessCm,flashThicknessCm)/IN_TO_CM;

    var compositeFormed=(target>=130 && pressure>=1 && consolidationIndex>=0.35);
    var flashingObserved=(flashFrac>=0.01);
    var voidsObserved=(infiltrationIndex<0.78 || consolidationIndex<0.75);
    var nomexFullyInfiltrated=(infiltrationIndex>=0.90 && target>=180 && soakDuration>=30);

    var finalRecovery=charge>0?100*finalComposite/charge:0;
    var totalRecovery=charge>0?100*(finalComposite+flashMass)/charge:0;
    var flashPct=charge>0?100*flashMass/charge:0;
    var lossPct=charge>0?100*processLoss/charge:0;

    var warnings=[];
    if(charge<=0) warnings.push('Loaded charge must be greater than zero.');
    if(tSoakStart<tTarget) warnings.push('Soak begins before the recorded target-temperature time.');
    if(tSoakEnd<tSoakStart) warnings.push('Soak end time is earlier than soak start time.');
    if(tFullP<tSoakEnd) warnings.push('Full-pressure time is earlier than the recorded soak end.');
    if(tOff<tFullP) warnings.push('Heating-off time is earlier than full-pressure application.');
    if(tEnd<tOff) warnings.push('Process end time is earlier than heating-off time.');
    if(trimmedThicknessCm>=dieDepthCm*0.999 && unconstrainedChargeVolume>dieCapacityCm3){
      warnings.push('Predicted consolidated volume exceeds the entered cavity capacity; excess material is forced into flash or loss.');
    }

    var lines=[
      '================ THERMOCOMPRESSION RESULT ================',
      'Loaded charge:                         '+f(charge,2)+' g',
      'Predicted final composite:             '+f(finalComposite,2)+' g',
      'Predicted recovered flash / trim:      '+f(flashMass,2)+' g',
      'Predicted unrecovered process loss:    '+f(processLoss,2)+' g',
      'Final-composite recovery:              '+f(finalRecovery,2)+' %',
      'Total material recovery:               '+f(totalRecovery,2)+' %',
      '',
      'Die cavity:                            '+f(dieLengthIn,2)+' x '+f(dieWidthIn,2)+' x '+f(dieDepthIn,2)+' in',
      'Compressed part without flash:         '+f(dieLengthIn,2)+' x '+f(dieWidthIn,2)+' x '+f(trimmedThicknessIn,3)+' in',
      'Compressed part including flash:       '+f(withFlashLengthIn,2)+' x '+f(withFlashWidthIn,2)+' x '+f(withFlashThicknessIn,3)+' in',
      '',
      'Target platen temperature:             '+f(target,1)+' C',
      'Final gauge pressure:                  '+f(pressure,2)+' MPa',
      'Thermal-soak duration:                 '+f(soakDuration,1)+' min',
      'Cooling duration:                      '+f(coolDuration,1)+' min',
      'Total process time:                    '+f(totalDuration,1)+' min',
      'Electrical energy used:                '+f(energy,4)+' kWh',
      'Energy per loaded mass:                '+f(energyPerKg,3)+' kWh/kg',
      '',
      'Composite formed:                      '+(compositeFormed?'Yes':'No'),
      'Polymer flashing predicted:            '+(flashingObserved?'Yes':'No'),
      'Internal or edge voids predicted:      '+(voidsObserved?'Yes':'No'),
      'Nomex fully infiltrated:               '+(nomexFullyInfiltrated?'Yes':'No')
    ];

    if(warnings.length){
      lines.push('');
      lines.push('CHECK INPUTS:');
      warnings.forEach(function(w){ lines.push('- '+w); });
    }
    var out=el('tc_full_out'); if(out) out.textContent=lines.join('\n');
  }

  document.addEventListener('click',function(e){
    var b=e.target.closest&&e.target.closest('#tc_full_run');
    if(!b) return;
    e.preventDefault();
    run();
  });
})();
</script>
</body>
